kernel void dequant_tiled_matmul_q8_0(
    device const uchar* W_q8     [[buffer(0)]],   // Q8_0 weights [N, K_bytes]
    device const float* X        [[buffer(1)]],   // [M, K] input batch
    device float*       Y        [[buffer(2)]],   // [M, N] output batch
    constant uint&      M        [[buffer(3)]],   // batch size
    constant uint&      N        [[buffer(4)]],   // output dim
    constant uint&      K        [[buffer(5)]],   // input dim (elements, not bytes)
    uint2 tg_pos                 [[threadgroup_position_in_grid]],
    ushort tiitg                 [[thread_index_in_threadgroup]],
    ushort sgitg                 [[simdgroup_index_in_threadgroup]])
{
    threadgroup half shmem[2048];
    threadgroup half* sa = shmem;
    threadgroup half* sb = shmem + TILE_M * TILE_K;

    uint tile_m_start = tg_pos.y * TILE_M;
    uint tile_n_start = tg_pos.x * TILE_N;

    ushort sg_r = sgitg / SG_COLS;
    ushort sg_c = sgitg % SG_COLS;

    simdgroup_float8x8 mc[2][2];
    FOR_UNROLL (ushort i = 0; i < 2; i++)
        FOR_UNROLL (ushort j = 0; j < 2; j++)
            mc[i][j] = make_filled_simdgroup_matrix<float, 8>(0.f);

    uint num_blocks_per_row = (K + Q8B_GROUP_SIZE - 1) / Q8B_GROUP_SIZE;
    uint row_bytes = num_blocks_per_row * Q8B_BLOCK_SIZE;

    uint num_k_tiles = (K + TILE_K - 1) / TILE_K;

    for (uint kt = 0; kt < num_k_tiles; kt++) {
        uint k_base = kt * TILE_K;

        // Load A tile: vectorized 2D mapping, 4 threads per row, 8 elements each via float4
        // FC_BC_M/FC_BC_K: when false (aligned), compiler eliminates boundary checks
        {
            ushort row = tiitg >> 2;           // tiitg / 4, range 0..31
            ushort col_group = tiitg & 3;      // tiitg % 4, range 0..3
            ushort k_start = col_group << 3;   // col_group * 8

            uint gm = tile_m_start + row;
            uint gk = k_base + k_start;
            threadgroup half* sa_ptr = sa + row * TILE_K + k_start;

            if (FC_BC_M || FC_BC_K) {
                // Boundary-checked path (compiled in only when dimensions may be unaligned)
                if (gm < M && gk + 7 < K) {
                    device const float4* x_ptr = (device const float4*)(X + gm * K + gk);
                    float4 v0 = x_ptr[0];
                    float4 v1 = x_ptr[1];
                    sa_ptr[0] = (half)v0.x; sa_ptr[1] = (half)v0.y;
                    sa_ptr[2] = (half)v0.z; sa_ptr[3] = (half)v0.w;
                    sa_ptr[4] = (half)v1.x; sa_ptr[5] = (half)v1.y;
                    sa_ptr[6] = (half)v1.z; sa_ptr[7] = (half)v1.w;
                } else {
                    FOR_UNROLL (ushort i = 0; i < 8; i++) {
                        uint gk_i = gk + i;
                        sa_ptr[i] = (gm < M && gk_i < K) ? (half)X[gm * K + gk_i] : (half)0.0h;
                    }
                }
            } else {
                // Fast path: no bounds checks needed (M aligned to TILE_M, K aligned to TILE_K)
                device const float4* x_ptr = (device const float4*)(X + gm * K + gk);
                float4 v0 = x_ptr[0];
                float4 v1 = x_ptr[1];
                sa_ptr[0] = (half)v0.x; sa_ptr[1] = (half)v0.y;
                sa_ptr[2] = (half)v0.z; sa_ptr[3] = (half)v0.w;
                sa_ptr[4] = (half)v1.x; sa_ptr[5] = (half)v1.y;
                sa_ptr[6] = (half)v1.z; sa_ptr[7] = (half)v1.w;
            }
        }

        // Load B tile: vectorized Q8_0 dequant (TILE_K=32 = Q8_0 block size)
        // 32 rows x 1 block/row = 32 blocks. 128 threads => 4 threads/row.
        // Each thread loads 8 consecutive int8 values (2 x uint) + 1 scale read.
        // FC_BC_N/FC_BC_K: when false (aligned), compiler eliminates boundary checks
        {
            uint block_idx = k_base / Q8B_GROUP_SIZE;
            ushort n_local = tiitg / 4;     // 0..31 (which row)
            ushort t_in_row = tiitg % 4;    // 0..3 (which quarter of the 32 elements)
            ushort k_offset = t_in_row * 8; // starting k position within block
            uint gn = tile_n_start + n_local;

            threadgroup half* sb_row = sb + n_local * TILE_K + k_offset;

            if (FC_BC_N || FC_BC_K) {
                // Boundary-checked path
                if (gn < N && k_base + k_offset < K) {
                    uint block_offset = gn * row_bytes + block_idx * Q8B_BLOCK_SIZE;
                    half scale = as_type<half>(*(device const ushort*)(W_q8 + block_offset));
                    device const char* qdata = (device const char*)(W_q8 + block_offset + 2 + k_offset);

                    uint k_remaining = K - (k_base + k_offset);
                    ushort count = (k_remaining >= 8) ? 8 : (ushort)k_remaining;

                    if (count == 8) {
                        sb_row[0] = scale * (half)qdata[0];
                        sb_row[1] = scale * (half)qdata[1];
                        sb_row[2] = scale * (half)qdata[2];
                        sb_row[3] = scale * (half)qdata[3];
                        sb_row[4] = scale * (half)qdata[4];
                        sb_row[5] = scale * (half)qdata[5];
                        sb_row[6] = scale * (half)qdata[6];
                        sb_row[7] = scale * (half)qdata[7];
                    } else {
                        for (ushort i = 0; i < count; i++) {
                            sb_row[i] = scale * (half)qdata[i];
                        }
                        for (ushort i = count; i < 8; i++) {
                            sb_row[i] = (half)0.0h;
                        }
                    }
                } else {
                    FOR_UNROLL (ushort i = 0; i < 8; i++) {
                        sb_row[i] = (half)0.0h;
                    }
                }
            } else {
                // Fast path: no bounds checks (N aligned to TILE_N, K aligned to TILE_K)
                uint block_offset = gn * row_bytes + block_idx * Q8B_BLOCK_SIZE;
                half scale = as_type<half>(*(device const ushort*)(W_q8 + block_offset));
                device const char* qdata = (device const char*)(W_q8 + block_offset + 2 + k_offset);

                sb_row[0] = scale * (half)qdata[0];
                sb_row[1] = scale * (half)qdata[1];
                sb_row[2] = scale * (half)qdata[2];
                sb_row[3] = scale * (half)qdata[3];
                sb_row[4] = scale * (half)qdata[4];
                sb_row[5] = scale * (half)qdata[5];
                sb_row[6] = scale * (half)qdata[6];
                sb_row[7] = scale * (half)qdata[7];
            }
        }

        threadgroup_barrier(mem_flags::mem_threadgroup);

        FOR_UNROLL (ushort ks = 0; ks < TILE_K; ks += 8) {
            simdgroup_half8x8 ma[2];
            simdgroup_barrier(mem_flags::mem_none);
            simdgroup_load(ma[0], sa + (sg_r * 16 + 0) * TILE_K + ks, TILE_K);
            simdgroup_load(ma[1], sa + (sg_r * 16 + 8) * TILE_K + ks, TILE_K);

            simdgroup_half8x8 mb[2];
            simdgroup_barrier(mem_flags::mem_none);
            simdgroup_load(mb[0], sb + (sg_c * 16 + 0) * TILE_K + ks, TILE_K, ulong2(0,0), true);
            simdgroup_load(mb[1], sb + (sg_c * 16 + 8) * TILE_K + ks, TILE_K, ulong2(0,0), true);

            simdgroup_barrier(mem_flags::mem_none);
            simdgroup_multiply_accumulate(mc[0][0], ma[0], mb[0], mc[0][0]);
            simdgroup_multiply_accumulate(mc[0][1], ma[0], mb[1], mc[0][1]);
            simdgroup_multiply_accumulate(mc[1][0], ma[1], mb[0], mc[1][0]);
            simdgroup_multiply_accumulate(mc[1][1], ma[1], mb[1], mc[1][1]);
        }

        threadgroup_barrier(mem_flags::mem_threadgroup);
    }

    uint sg_m_base = tile_m_start + sg_r * 16;
    uint sg_n_base = tile_n_start + sg_c * 16;

    if (FC_BC_M || FC_BC_N) {
        // Boundary-checked store path
        if (sg_m_base + 16 <= M && sg_n_base + 16 <= N) {
            FOR_UNROLL (ushort i = 0; i < 2; i++)
                FOR_UNROLL (ushort j = 0; j < 2; j++)
                    simdgroup_store(mc[i][j], Y + (sg_m_base + i * 8) * N + (sg_n_base + j * 8), N);
        } else {
            threadgroup float* sc = (threadgroup float*)shmem;
            threadgroup float* my_sc = sc + sgitg * 256;
            FOR_UNROLL (ushort i = 0; i < 2; i++)
                FOR_UNROLL (ushort j = 0; j < 2; j++)
                    simdgroup_store(mc[i][j], my_sc + (i * 8) * 16 + (j * 8), 16);
            threadgroup_barrier(mem_flags::mem_threadgroup);
            ushort lane = tiitg % 32;
            for (ushort idx = lane; idx < 256; idx += 32) {
                ushort local_m = idx / 16;
                ushort local_n = idx % 16;
                uint gm = sg_m_base + local_m;
                uint gn = sg_n_base + local_n;
                if (gm < M && gn < N) {
                    Y[gm * N + gn] = my_sc[local_m * 16 + local_n];
                }
            }
        }
    } else {
        // Fast path: direct store (M and N aligned to tile dimensions)
        FOR_UNROLL (ushort i = 0; i < 2; i++)
            FOR_UNROLL (ushort j = 0; j < 2; j++)
                simdgroup_store(mc[i][j], Y + (sg_m_base + i * 8) * N + (sg_n_base + j * 8), N);
    }
}

constant constexpr uint TILE_K_64 = 64;

// ============================================================================
// dequant_tiled_matmul_q8_0_k64: TILE_K=64 variant for fewer barriers
//
// Same algorithm as dequant_tiled_matmul_q8_0 but processes 2 Q8_0 blocks per
// K-step instead of 1. This halves the number of threadgroup barriers (from
// K/32 to K/64) and K-loop iterations, improving efficiency for large-K GEMMs.
//
// Shared memory: sa[32*64] + sb[32*64] = 4096 halfs = 8192 bytes
// (still well within 32KB threadgroup limit; occupancy >= 2 TG/CU)
//
// A-tile loading: 128 threads, 32 rows x 4 threads/row, each loads 16 elems
// (two float4 reads). 4 threads * 16 = 64 = TILE_K_64.
//
// B-tile loading: 2-pass approach. Each pass loads one Q8_0 block (32 elems)
// across 32 rows using 128 threads mapped as 32 rows x 4 threads/row.
// ============================================================================

kernel void dequant_tiled_matmul_q8_0_k64(
    device const uchar* W_q8     [[buffer(0)]],   // Q8_0 weights [N, K_bytes]
    device const float* X        [[buffer(1)]],   // [M, K] input batch
    device float*       Y        [[buffer(2)]],   // [M, N] output batch
    constant uint&      M        [[buffer(3)]],   // batch size
    constant uint&      N        [[buffer(4)]],   // output dim
    constant uint&      K        [[buffer(5)]],   // input dim (elements, not bytes)
    uint2 tg_pos                 [[threadgroup_position_in_grid]],
    ushort tiitg                 [[thread_index_in_threadgroup]],
    ushort sgitg                 [[simdgroup_index_in_threadgroup]])
{
    threadgroup half shmem_k64[4096];  // sa[32*64] + sb[32*64]
    threadgroup half* sa = shmem_k64;
    threadgroup half* sb = shmem_k64 + TILE_M * TILE_K_64;

    uint tile_m_start = tg_pos.y * TILE_M;
    uint tile_n_start = tg_pos.x * TILE_N;

    ushort sg_r = sgitg / SG_COLS;
    ushort sg_c = sgitg % SG_COLS;

    simdgroup_float8x8 mc[2][2];
    FOR_UNROLL (ushort i = 0; i < 2; i++)
        FOR_UNROLL (ushort j = 0; j < 2; j++)
            mc[i][j] = make_filled_simdgroup_matrix<float, 8>(0.f);

    uint num_blocks_per_row = (K + Q8B_GROUP_SIZE - 1) / Q8B_GROUP_SIZE;
    uint row_bytes = num_blocks_per_row * Q8B_BLOCK_SIZE;

    uint num_k_tiles = (K + TILE_K_64 - 1) / TILE_K_64;

    for (uint kt = 0; kt < num_k_tiles; kt++) {
        uint k_base = kt * TILE_K_64;

        // Load A tile: 32 rows x 64 cols
        // FC_BC_M/FC_BC_K: when false (aligned), compiler eliminates boundary checks
        {
            ushort row = tiitg >> 2;           // tiitg / 4, range 0..31
            ushort col_group = tiitg & 3;      // tiitg % 4, range 0..3
            ushort k_start = col_group << 4;   // col_group * 16

            uint gm = tile_m_start + row;
            uint gk = k_base + k_start;
            threadgroup half* sa_ptr = sa + row * TILE_K_64 + k_start;

            if (FC_BC_M || FC_BC_K) {
                if (gm < M && gk + 15 < K) {
                    device const float4* x_ptr = (device const float4*)(X + gm * K + gk);
                    float4 v0 = x_ptr[0];
                    float4 v1 = x_ptr[1];
                    float4 v2 = x_ptr[2];
                    float4 v3 = x_ptr[3];
                    sa_ptr[0]  = (half)v0.x; sa_ptr[1]  = (half)v0.y;
                    sa_ptr[2]  = (half)v0.z; sa_ptr[3]  = (half)v0.w;
                    sa_ptr[4]  = (half)v1.x; sa_ptr[5]  = (half)v1.y;
                    sa_ptr[6]  = (half)v1.z; sa_ptr[7]  = (half)v1.w;
                    sa_ptr[8]  = (half)v2.x; sa_ptr[9]  = (half)v2.y;
                    sa_ptr[10] = (half)v2.z; sa_ptr[11] = (half)v2.w;
                    sa_ptr[12] = (half)v3.x; sa_ptr[13] = (half)v3.y;
                    sa_ptr[14] = (half)v3.z; sa_ptr[15] = (half)v3.w;
                } else {
                    FOR_UNROLL (ushort i = 0; i < 16; i++) {
                        uint gk_i = gk + i;
                        sa_ptr[i] = (gm < M && gk_i < K) ? (half)X[gm * K + gk_i] : (half)0.0h;
                    }
                }
            } else {
                device const float4* x_ptr = (device const float4*)(X + gm * K + gk);
                float4 v0 = x_ptr[0];
                float4 v1 = x_ptr[1];
                float4 v2 = x_ptr[2];
                float4 v3 = x_ptr[3];
                sa_ptr[0]  = (half)v0.x; sa_ptr[1]  = (half)v0.y;
                sa_ptr[2]  = (half)v0.z; sa_ptr[3]  = (half)v0.w;
                sa_ptr[4]  = (half)v1.x; sa_ptr[5]  = (half)v1.y;
                sa_ptr[6]  = (half)v1.z; sa_ptr[7]  = (half)v1.w;
                sa_ptr[8]  = (half)v2.x; sa_ptr[9]  = (half)v2.y;
                sa_ptr[10] = (half)v2.z; sa_ptr[11] = (half)v2.w;
                sa_ptr[12] = (half)v3.x; sa_ptr[13] = (half)v3.y;
                sa_ptr[14] = (half)v3.z; sa_ptr[15] = (half)v3.w;
            }
        }

        // Load B tile: 32 rows x 64 cols = 2 Q8_0 blocks per row
        // FC_BC_N/FC_BC_K: when false (aligned), compiler eliminates boundary checks
        {
            ushort n_local = tiitg >> 2;       // 0..31 (which row)
            ushort t_in_row = tiitg & 3;       // 0..3 (quarter of 32 elements)
            uint gn = tile_n_start + n_local;

            // Pass 0: first Q8_0 block (k_base + 0..31)
            {
                uint block_idx = k_base / Q8B_GROUP_SIZE;
                ushort k_offset = t_in_row * 8;
                threadgroup half* sb_row = sb + n_local * TILE_K_64 + k_offset;

                if (FC_BC_N || FC_BC_K) {
                    if (gn < N && k_base + k_offset < K) {
                        uint block_offset = gn * row_bytes + block_idx * Q8B_BLOCK_SIZE;
                        half scale = as_type<half>(*(device const ushort*)(W_q8 + block_offset));
                        device const char* qdata = (device const char*)(W_q8 + block_offset + 2 + k_offset);

                        uint k_remaining = K - (k_base + k_offset);
                        ushort count = (k_remaining >= 8) ? 8 : (ushort)k_remaining;

                        if (count == 8) {
                            sb_row[0] = scale * (half)qdata[0];
                            sb_row[1] = scale * (half)qdata[1];
                            sb_row[2] = scale * (half)qdata[2];
                            sb_row[3] = scale * (half)qdata[3];
                            sb_row[4] = scale * (half)qdata[4];
                            sb_row[5] = scale * (half)qdata[5];
                            sb_row[6] = scale * (half)qdata[6];
                            sb_row[7] = scale * (half)qdata[7];
                        } else {
                            for (ushort i = 0; i < count; i++) {
                                sb_row[i] = scale * (half)qdata[i];
                            }
                            for (ushort i = count; i < 8; i++) {
                                sb_row[i] = (half)0.0h;
                            }
                        }
                    } else {
                        FOR_UNROLL (ushort i = 0; i < 8; i++) {
                            sb_row[i] = (half)0.0h;
                        }
                    }
                } else {
                    uint block_offset = gn * row_bytes + block_idx * Q8B_BLOCK_SIZE;
                    half scale = as_type<half>(*(device const ushort*)(W_q8 + block_offset));
                    device const char* qdata = (device const char*)(W_q8 + block_offset + 2 + k_offset);
                    sb_row[0] = scale * (half)qdata[0];
                    sb_row[1] = scale * (half)qdata[1];
                    sb_row[2] = scale * (half)qdata[2];
                    sb_row[3] = scale * (half)qdata[3];
                    sb_row[4] = scale * (half)qdata[4];
                    sb_row[5] = scale * (half)qdata[5];
                    sb_row[6] = scale * (half)qdata[6];
                    sb_row[7] = scale * (half)qdata[7];
                }
            }

            // Pass 1: second Q8_0 block (k_base + 32..63)
            {
                uint block_idx = (k_base + 32) / Q8B_GROUP_SIZE;
                ushort k_offset = t_in_row * 8;
                threadgroup half* sb_row = sb + n_local * TILE_K_64 + 32 + k_offset;

                if (FC_BC_N || FC_BC_K) {
                    if (gn < N && k_base + 32 + k_offset < K) {
                        uint block_offset = gn * row_bytes + block_idx * Q8B_BLOCK_SIZE;
                        half scale = as_type<half>(*(device const ushort*)(W_q8 + block_offset));
                        device const char* qdata = (device const char*)(W_q8 + block_offset + 2 + k_offset);

                        uint k_remaining = K - (k_base + 32 + k_offset);
                        ushort count = (k_remaining >= 8) ? 8 : (ushort)k_remaining;

                        if (count == 8) {
                            sb_row[0] = scale * (half)qdata[0];
                            sb_row[1] = scale * (half)qdata[1];
                            sb_row[2] = scale * (half)qdata[2];
                            sb_row[3] = scale * (half)qdata[3];
                            sb_row[4] = scale * (half)qdata[4];
                            sb_row[5] = scale * (half)qdata[5];
                            sb_row[6] = scale * (half)qdata[6];
                            sb_row[7] = scale * (half)qdata[7];
                        } else {
                            for (ushort i = 0; i < count; i++) {
                                sb_row[i] = scale * (half)qdata[i];
                            }
                            for (ushort i = count; i < 8; i++) {
                                sb_row[i] = (half)0.0h;
                            }
                        }
                    } else {
                        FOR_UNROLL (ushort i = 0; i < 8; i++) {
                            sb_row[i] = (half)0.0h;
                        }
                    }
                } else {
                    uint block_offset = gn * row_bytes + block_idx * Q8B_BLOCK_SIZE;
                    half scale = as_type<half>(*(device const ushort*)(W_q8 + block_offset));
                    device const char* qdata = (device const char*)(W_q8 + block_offset + 2 + k_offset);
                    sb_row[0] = scale * (half)qdata[0];
                    sb_row[1] = scale * (half)qdata[1];
                    sb_row[2] = scale * (half)qdata[2];
                    sb_row[3] = scale * (half)qdata[3];
                    sb_row[4] = scale * (half)qdata[4];
                    sb_row[5] = scale * (half)qdata[5];
                    sb_row[6] = scale * (half)qdata[6];
                    sb_row[7] = scale * (half)qdata[7];
                }
            }
        }

        threadgroup_barrier(mem_flags::mem_threadgroup);

        // MMA: 8 iterations (TILE_K_64=64, step by 8)
        FOR_UNROLL (ushort ks = 0; ks < TILE_K_64; ks += 8) {
            simdgroup_half8x8 ma[2];
            simdgroup_barrier(mem_flags::mem_none);
            simdgroup_load(ma[0], sa + (sg_r * 16 + 0) * TILE_K_64 + ks, TILE_K_64);
            simdgroup_load(ma[1], sa + (sg_r * 16 + 8) * TILE_K_64 + ks, TILE_K_64);

            simdgroup_half8x8 mb[2];
            simdgroup_barrier(mem_flags::mem_none);
            simdgroup_load(mb[0], sb + (sg_c * 16 + 0) * TILE_K_64 + ks, TILE_K_64, ulong2(0,0), true);
            simdgroup_load(mb[1], sb + (sg_c * 16 + 8) * TILE_K_64 + ks, TILE_K_64, ulong2(0,0), true);

            simdgroup_barrier(mem_flags::mem_none);
            simdgroup_multiply_accumulate(mc[0][0], ma[0], mb[0], mc[0][0]);
            simdgroup_multiply_accumulate(mc[0][1], ma[0], mb[1], mc[0][1]);
            simdgroup_multiply_accumulate(mc[1][0], ma[1], mb[0], mc[1][0]);
            simdgroup_multiply_accumulate(mc[1][1], ma[1], mb[1], mc[1][1]);
        }

        threadgroup_barrier(mem_flags::mem_threadgroup);
    }

    // Store results
    uint sg_m_base = tile_m_start + sg_r * 16;
    uint sg_n_base = tile_n_start + sg_c * 16;

    if (FC_BC_M || FC_BC_N) {
        if (sg_m_base + 16 <= M && sg_n_base + 16 <= N) {
            FOR_UNROLL (ushort i = 0; i < 2; i++)
                FOR_UNROLL (ushort j = 0; j < 2; j++)
                    simdgroup_store(mc[i][j], Y + (sg_m_base + i * 8) * N + (sg_n_base + j * 8), N);
        } else {
            threadgroup float* sc = (threadgroup float*)shmem_k64;
            threadgroup float* my_sc = sc + sgitg * 256;
            FOR_UNROLL (ushort i = 0; i < 2; i++)
                FOR_UNROLL (ushort j = 0; j < 2; j++)
                    simdgroup_store(mc[i][j], my_sc + (i * 8) * 16 + (j * 8), 16);
            threadgroup_barrier(mem_flags::mem_threadgroup);
            ushort lane = tiitg % 32;
            for (ushort idx = lane; idx < 256; idx += 32) {
                ushort local_m = idx / 16;
                ushort local_n = idx % 16;
                uint gm = sg_m_base + local_m;
                uint gn = sg_n_base + local_n;
                if (gm < M && gn < N) {
                    Y[gm * N + gn] = my_sc[local_m * 16 + local_n];
                }
            }
        }
    } else {
        FOR_UNROLL (ushort i = 0; i < 2; i++)
            FOR_UNROLL (ushort j = 0; j < 2; j++)
                simdgroup_store(mc[i][j], Y + (sg_m_base + i * 8) * N + (sg_n_base + j * 8), N);
    }
}

// ============================================================================
// dequant_tiled_matmul_q8_0_k64_residual_batched: K64 variant + residual add
//
// Y[m,n] = X[M,K] * dequant(W_q8[N,K_bytes])^T + R[m,n]
// Same as dequant_tiled_matmul_q8_0_k64 but fuses residual add at writeback.
// ============================================================================

kernel void dequant_tiled_matmul_q8_0_k64_residual_batched(
    device const uchar* W_q8     [[buffer(0)]],   // Q8_0 weights [N, K_bytes]
    device const float* X        [[buffer(1)]],   // [M, K] input batch
    device float*       Y        [[buffer(2)]],   // [M, N] output batch
    constant uint&      M        [[buffer(3)]],   // batch size
    constant uint&      N        [[buffer(4)]],   // output dim
    constant uint&      K        [[buffer(5)]],   // input dim (elements, not bytes)
    device const float* R        [[buffer(6)]],   // [M, N] residual to add
    uint2 tg_pos                 [[threadgroup_position_in_grid]],
    ushort tiitg                 [[thread_index_in_threadgroup]],
    ushort sgitg                 [[simdgroup_index_in_threadgroup]])
{
    threadgroup half shmem_k64r[4096];
    threadgroup half* sa = shmem_k64r;
    threadgroup half* sb = shmem_k64r + TILE_M * TILE_K_64;

    uint tile_m_start = tg_pos.y * TILE_M;
    uint tile_n_start = tg_pos.x * TILE_N;

    ushort sg_r = sgitg / SG_COLS;
    ushort sg_c = sgitg % SG_COLS;

    simdgroup_float8x8 mc[2][2];
    FOR_UNROLL (ushort i = 0; i < 2; i++)
        FOR_UNROLL (ushort j = 0; j < 2; j++)
            mc[i][j] = make_filled_simdgroup_matrix<float, 8>(0.f);

    uint num_blocks_per_row = (K + Q8B_GROUP_SIZE - 1) / Q8B_GROUP_SIZE;
    uint row_bytes = num_blocks_per_row * Q8B_BLOCK_SIZE;

    uint num_k_tiles = (K + TILE_K_64 - 1) / TILE_K_64;

    for (uint kt = 0; kt < num_k_tiles; kt++) {
        uint k_base = kt * TILE_K_64;

        // Load A tile: 32 rows x 64 cols
        // FC_BC_M/FC_BC_K: when false (aligned), compiler eliminates boundary checks
        {
            ushort row = tiitg >> 2;
            ushort col_group = tiitg & 3;
            ushort k_start = col_group << 4;   // col_group * 16

            uint gm = tile_m_start + row;
            uint gk = k_base + k_start;
            threadgroup half* sa_ptr = sa + row * TILE_K_64 + k_start;

            if (FC_BC_M || FC_BC_K) {
                if (gm < M && gk + 15 < K) {
                    device const float4* x_ptr = (device const float4*)(X + gm * K + gk);
                    float4 v0 = x_ptr[0];
                    float4 v1 = x_ptr[1];
                    float4 v2 = x_ptr[2];
                    float4 v3 = x_ptr[3];
                    sa_ptr[0]  = (half)v0.x; sa_ptr[1]  = (half)v0.y;
                    sa_ptr[2]  = (half)v0.z; sa_ptr[3]  = (half)v0.w;
                    sa_ptr[4]  = (half)v1.x; sa_ptr[5]  = (half)v1.y;
                    sa_ptr[6]  = (half)v1.z; sa_ptr[7]  = (half)v1.w;
                    sa_ptr[8]  = (half)v2.x; sa_ptr[9]  = (half)v2.y;
                    sa_ptr[10] = (half)v2.z; sa_ptr[11] = (half)v2.w;
                    sa_ptr[12] = (half)v3.x; sa_ptr[13] = (half)v3.y;
                    sa_ptr[14] = (half)v3.z; sa_ptr[15] = (half)v3.w;
                } else {
                    FOR_UNROLL (ushort i = 0; i < 16; i++) {
                        uint gk_i = gk + i;
                        sa_ptr[i] = (gm < M && gk_i < K) ? (half)X[gm * K + gk_i] : (half)0.0h;
                    }
                }
            } else {
                device const float4* x_ptr = (device const float4*)(X + gm * K + gk);
                float4 v0 = x_ptr[0];
                float4 v1 = x_ptr[1];
                float4 v2 = x_ptr[2];
                float4 v3 = x_ptr[3];
                sa_ptr[0]  = (half)v0.x; sa_ptr[1]  = (half)v0.y;
                sa_ptr[2]  = (half)v0.z; sa_ptr[3]  = (half)v0.w;
                sa_ptr[4]  = (half)v1.x; sa_ptr[5]  = (half)v1.y;
                sa_ptr[6]  = (half)v1.z; sa_ptr[7]  = (half)v1.w;
                sa_ptr[8]  = (half)v2.x; sa_ptr[9]  = (half)v2.y;
                sa_ptr[10] = (half)v2.z; sa_ptr[11] = (half)v2.w;
                sa_ptr[12] = (half)v3.x; sa_ptr[13] = (half)v3.y;
                sa_ptr[14] = (half)v3.z; sa_ptr[15] = (half)v3.w;
            }
        }

        // Load B tile: 2-pass Q8_0 dequant (2 blocks per row)
        // FC_BC_N/FC_BC_K: when false (aligned), compiler eliminates boundary checks
        {
            ushort n_local = tiitg >> 2;
            ushort t_in_row = tiitg & 3;
            uint gn = tile_n_start + n_local;

            // Pass 0: first block (k_base + 0..31)
            {
                uint block_idx = k_base / Q8B_GROUP_SIZE;
                ushort k_offset = t_in_row * 8;
                threadgroup half* sb_row = sb + n_local * TILE_K_64 + k_offset;

                if (FC_BC_N || FC_BC_K) {
                    if (gn < N && k_base + k_offset < K) {
                        uint block_offset = gn * row_bytes + block_idx * Q8B_BLOCK_SIZE;
                        half scale = as_type<half>(*(device const ushort*)(W_q8 + block_offset));
                        device const char* qdata = (device const char*)(W_q8 + block_offset + 2 + k_offset);

                        uint k_remaining = K - (k_base + k_offset);
                        ushort count = (k_remaining >= 8) ? 8 : (ushort)k_remaining;

                        if (count == 8) {
                            sb_row[0] = scale * (half)qdata[0];
                            sb_row[1] = scale * (half)qdata[1];
                            sb_row[2] = scale * (half)qdata[2];
                            sb_row[3] = scale * (half)qdata[3];
                            sb_row[4] = scale * (half)qdata[4];
                            sb_row[5] = scale * (half)qdata[5];
                            sb_row[6] = scale * (half)qdata[6];
                            sb_row[7] = scale * (half)qdata[7];
                        } else {
                            for (ushort i = 0; i < count; i++) {
                                sb_row[i] = scale * (half)qdata[i];
                            }
                            for (ushort i = count; i < 8; i++) {
                                sb_row[i] = (half)0.0h;
                            }
                        }
                    } else {
                        FOR_UNROLL (ushort i = 0; i < 8; i++) {
                            sb_row[i] = (half)0.0h;
                        }
                    }
                } else {
                    uint block_offset = gn * row_bytes + block_idx * Q8B_BLOCK_SIZE;
                    half scale = as_type<half>(*(device const ushort*)(W_q8 + block_offset));
                    device const char* qdata = (device const char*)(W_q8 + block_offset + 2 + k_offset);
                    sb_row[0] = scale * (half)qdata[0];
                    sb_row[1] = scale * (half)qdata[1];
                    sb_row[2] = scale * (half)qdata[2];
                    sb_row[3] = scale * (half)qdata[3];
                    sb_row[4] = scale * (half)qdata[4];
                    sb_row[5] = scale * (half)qdata[5];
                    sb_row[6] = scale * (half)qdata[6];
                    sb_row[7] = scale * (half)qdata[7];
                }
            }

            // Pass 1: second block (k_base + 32..63)
            {
                uint block_idx = (k_base + 32) / Q8B_GROUP_SIZE;
                ushort k_offset = t_in_row * 8;
                threadgroup half* sb_row = sb + n_local * TILE_K_64 + 32 + k_offset;

                if (FC_BC_N || FC_BC_K) {
                    if (gn < N && k_base + 32 + k_offset < K) {
                        uint block_offset = gn * row_bytes + block_idx * Q8B_BLOCK_SIZE;
                        half scale = as_type<half>(*(device const ushort*)(W_q8 + block_offset));
                        device const char* qdata = (device const char*)(W_q8 + block_offset + 2 + k_offset);

                        uint k_remaining = K - (k_base + 32 + k_offset);
                        ushort count = (k_remaining >= 8) ? 8 : (ushort)k_remaining;

                        if (count == 8) {
                            sb_row[0] = scale * (half)qdata[0];
                            sb_row[1] = scale * (half)qdata[1];
                            sb_row[2] = scale * (half)qdata[2];
                            sb_row[3] = scale * (half)qdata[3];
                            sb_row[4] = scale * (half)qdata[4];
                            sb_row[5] = scale * (half)qdata[5];
                            sb_row[6] = scale * (half)qdata[6];
                            sb_row[7] = scale * (half)qdata[7];
                        } else {
                            for (ushort i = 0; i < count; i++) {
                                sb_row[i] = scale * (half)qdata[i];
                            }
                            for (ushort i = count; i < 8; i++) {
                                sb_row[i] = (half)0.0h;
                            }
                        }
                    } else {
                        FOR_UNROLL (ushort i = 0; i < 8; i++) {
                            sb_row[i] = (half)0.0h;
                        }
                    }
                } else {
                    uint block_offset = gn * row_bytes + block_idx * Q8B_BLOCK_SIZE;
                    half scale = as_type<half>(*(device const ushort*)(W_q8 + block_offset));
                    device const char* qdata = (device const char*)(W_q8 + block_offset + 2 + k_offset);
                    sb_row[0] = scale * (half)qdata[0];
                    sb_row[1] = scale * (half)qdata[1];
                    sb_row[2] = scale * (half)qdata[2];
                    sb_row[3] = scale * (half)qdata[3];
                    sb_row[4] = scale * (half)qdata[4];
                    sb_row[5] = scale * (half)qdata[5];
                    sb_row[6] = scale * (half)qdata[6];
                    sb_row[7] = scale * (half)qdata[7];
                }
            }
        }

        threadgroup_barrier(mem_flags::mem_threadgroup);

        FOR_UNROLL (ushort ks = 0; ks < TILE_K_64; ks += 8) {
            simdgroup_half8x8 ma[2];
            simdgroup_barrier(mem_flags::mem_none);
            simdgroup_load(ma[0], sa + (sg_r * 16 + 0) * TILE_K_64 + ks, TILE_K_64);
            simdgroup_load(ma[1], sa + (sg_r * 16 + 8) * TILE_K_64 + ks, TILE_K_64);

            simdgroup_half8x8 mb[2];
            simdgroup_barrier(mem_flags::mem_none);
            simdgroup_load(mb[0], sb + (sg_c * 16 + 0) * TILE_K_64 + ks, TILE_K_64, ulong2(0,0), true);
            simdgroup_load(mb[1], sb + (sg_c * 16 + 8) * TILE_K_64 + ks, TILE_K_64, ulong2(0,0), true);

            simdgroup_barrier(mem_flags::mem_none);
            simdgroup_multiply_accumulate(mc[0][0], ma[0], mb[0], mc[0][0]);
            simdgroup_multiply_accumulate(mc[0][1], ma[0], mb[1], mc[0][1]);
            simdgroup_multiply_accumulate(mc[1][0], ma[1], mb[0], mc[1][0]);
            simdgroup_multiply_accumulate(mc[1][1], ma[1], mb[1], mc[1][1]);
        }

        threadgroup_barrier(mem_flags::mem_threadgroup);
    }

    // Store results with residual add: Y[m,n] = GEMM[m,n] + R[m,n]
    uint sg_m_base = tile_m_start + sg_r * 16;
    uint sg_n_base = tile_n_start + sg_c * 16;

    {
        threadgroup float* sc = (threadgroup float*)shmem_k64r;
        threadgroup float* my_sc = sc + sgitg * 256;
        FOR_UNROLL (ushort i = 0; i < 2; i++)
            FOR_UNROLL (ushort j = 0; j < 2; j++)
                simdgroup_store(mc[i][j], my_sc + (i * 8) * 16 + (j * 8), 16);
        threadgroup_barrier(mem_flags::mem_threadgroup);
        ushort lane = tiitg % 32;
        if (FC_BC_M || FC_BC_N) {
            for (ushort idx = lane; idx < 256; idx += 32) {
                ushort local_m = idx / 16;
                ushort local_n = idx % 16;
                uint gm = sg_m_base + local_m;
                uint gn = sg_n_base + local_n;
                if (gm < M && gn < N) {
                    Y[gm * N + gn] = my_sc[local_m * 16 + local_n] + R[gm * N + gn];
                }
            }
        } else {
            for (ushort idx = lane; idx < 256; idx += 32) {
                ushort local_m = idx / 16;
                ushort local_n = idx % 16;
                uint gm = sg_m_base + local_m;
                uint gn = sg_n_base + local_n;
                Y[gm * N + gn] = my_sc[local_m * 16 + local_n] + R[gm * N + gn];
            }
        }
    }
}

// ============================================================================
// dequant_tiled_matmul_q8_0_gate_up_swiglu_fused: Joint dual-output gate+up
// GEMM with register-resident SwiGLU writeback.
//
// Replaces the three-dispatch chain (gate GEMM, up GEMM, swiglu_batched) used
// by the FFN prefill path with a single kernel that:
//   1. Reads the A-tile (token activations) once into shmem.
//   2. Dequantizes BOTH gate and up Q8_0 tiles into separate shmem regions.
//   3. Computes both gate and up output tiles via simdgroup MMA in registers.
//   4. Applies SwiGLU (silu(gate) * up) in registers at the epilogue.
//   5. Writes only the SwiGLU activation to global memory.
//
// Threadgroup memory:
//   sa[TILE_M * TILE_K_64] = 32 * 64 = 2048 halfs = 4 KB  (shared A tile)
//   sb_gate[TILE_N * TILE_K_64] = 32 * 64 = 2048 halfs = 4 KB
//   sb_up  [TILE_N * TILE_K_64] = 32 * 64 = 2048 halfs = 4 KB
//   total = 6144 halfs = 12 KB
// This sits at exactly the M3-Ultra 12 KB shmem budget identified
// (16 KB knee). At 12 KB, occupancy is 2 TG/CU which preserves latency hiding.
//
// Output: writes [M, N] float activation to Y. Eliminates the gate_buf and
// up_buf hidden_inter (M * inter_dim) writes and reads.
//
// Bandwidth model on Qwen3.5-9B (M=131 inter_dim=12288 hidden_dim=4096):
//   Saved: 2 * M * N * sizeof(float) = 2 * 131 * 12288 * 4 = ~12.6 MB / layer
//   That's ~400 MB across 32 layers, at ~210 GB/s effective = ~2 ms saved.
//   Plus 2 fewer compute encoder submissions per layer = ~64 fewer dispatches
//   over the prefill iteration. Each dispatch saves ~5-20 us of overhead.
//
// Function constants FC_BC_M / FC_BC_N / FC_BC_K control boundary handling
// (same as the K=64 kernel they replace).
// ============================================================================

kernel void dequant_tiled_matmul_q8_0_gate_up_swiglu_fused(
    device const uchar* W_gate   [[buffer(0)]],   // Q8_0 gate weights [N, K_bytes]
    device const float* X        [[buffer(1)]],   // [M, K] input activations
    device float*       Y        [[buffer(2)]],   // [M, N] SwiGLU output
    constant uint&      M        [[buffer(3)]],   // batch size
    constant uint&      N        [[buffer(4)]],   // inter_dim
    constant uint&      K        [[buffer(5)]],   // hidden_dim
    device const uchar* W_up     [[buffer(6)]],   // Q8_0 up weights [N, K_bytes]
    uint2 tg_pos                 [[threadgroup_position_in_grid]],
    ushort tiitg                 [[thread_index_in_threadgroup]],
    ushort sgitg                 [[simdgroup_index_in_threadgroup]])
{
    // 6144 halfs = 12 KB threadgroup memory (under 16 KB knee, 2 TG/CU on M3).
    threadgroup half shmem_gus[6144];
    threadgroup half* sa     = shmem_gus;
    threadgroup half* sb_g   = shmem_gus + TILE_M * TILE_K_64;            // gate B tile
    threadgroup half* sb_u   = shmem_gus + TILE_M * TILE_K_64 + TILE_N * TILE_K_64;  // up B tile

    uint tile_m_start = tg_pos.y * TILE_M;
    uint tile_n_start = tg_pos.x * TILE_N;

    ushort sg_r = sgitg / SG_COLS;
    ushort sg_c = sgitg % SG_COLS;

    // Two output accumulators: gate and up.
    simdgroup_float8x8 mc_g[2][2];
    simdgroup_float8x8 mc_u[2][2];
    FOR_UNROLL (ushort i = 0; i < 2; i++)
        FOR_UNROLL (ushort j = 0; j < 2; j++) {
            mc_g[i][j] = make_filled_simdgroup_matrix<float, 8>(0.f);
            mc_u[i][j] = make_filled_simdgroup_matrix<float, 8>(0.f);
        }

    uint num_blocks_per_row = (K + Q8B_GROUP_SIZE - 1) / Q8B_GROUP_SIZE;
    uint row_bytes = num_blocks_per_row * Q8B_BLOCK_SIZE;

    uint num_k_tiles = (K + TILE_K_64 - 1) / TILE_K_64;

    for (uint kt = 0; kt < num_k_tiles; kt++) {
        uint k_base = kt * TILE_K_64;

        // ---- Load A tile (X): 32 rows x 64 cols. Same layout as q8_0_k64. ----
        {
            ushort row = tiitg >> 2;
            ushort col_group = tiitg & 3;
            ushort k_start = col_group << 4;   // col_group * 16

            uint gm = tile_m_start + row;
            uint gk = k_base + k_start;
            threadgroup half* sa_ptr = sa + row * TILE_K_64 + k_start;

            if (FC_BC_M || FC_BC_K) {
                if (gm < M && gk + 15 < K) {
                    device const float4* x_ptr = (device const float4*)(X + gm * K + gk);
                    float4 v0 = x_ptr[0];
                    float4 v1 = x_ptr[1];
                    float4 v2 = x_ptr[2];
                    float4 v3 = x_ptr[3];
                    sa_ptr[0]  = (half)v0.x; sa_ptr[1]  = (half)v0.y;
                    sa_ptr[2]  = (half)v0.z; sa_ptr[3]  = (half)v0.w;
                    sa_ptr[4]  = (half)v1.x; sa_ptr[5]  = (half)v1.y;
                    sa_ptr[6]  = (half)v1.z; sa_ptr[7]  = (half)v1.w;
                    sa_ptr[8]  = (half)v2.x; sa_ptr[9]  = (half)v2.y;
                    sa_ptr[10] = (half)v2.z; sa_ptr[11] = (half)v2.w;
                    sa_ptr[12] = (half)v3.x; sa_ptr[13] = (half)v3.y;
                    sa_ptr[14] = (half)v3.z; sa_ptr[15] = (half)v3.w;
                } else {
                    FOR_UNROLL (ushort i = 0; i < 16; i++) {
                        uint gk_i = gk + i;
                        sa_ptr[i] = (gm < M && gk_i < K) ? (half)X[gm * K + gk_i] : (half)0.0h;
                    }
                }
            } else {
                device const float4* x_ptr = (device const float4*)(X + gm * K + gk);
                float4 v0 = x_ptr[0];
                float4 v1 = x_ptr[1];
                float4 v2 = x_ptr[2];
                float4 v3 = x_ptr[3];
                sa_ptr[0]  = (half)v0.x; sa_ptr[1]  = (half)v0.y;
                sa_ptr[2]  = (half)v0.z; sa_ptr[3]  = (half)v0.w;
                sa_ptr[4]  = (half)v1.x; sa_ptr[5]  = (half)v1.y;
                sa_ptr[6]  = (half)v1.z; sa_ptr[7]  = (half)v1.w;
                sa_ptr[8]  = (half)v2.x; sa_ptr[9]  = (half)v2.y;
                sa_ptr[10] = (half)v2.z; sa_ptr[11] = (half)v2.w;
                sa_ptr[12] = (half)v3.x; sa_ptr[13] = (half)v3.y;
                sa_ptr[14] = (half)v3.z; sa_ptr[15] = (half)v3.w;
            }
        }

        // ---- Load B-gate tile + B-up tile: 32 rows x 64 cols each. ----
        // Same 2-pass pattern as q8_0_k64 but for two distinct weight buffers.
        {
            ushort n_local = tiitg >> 2;
            ushort t_in_row = tiitg & 3;
            ushort k_offset = t_in_row * 8;
            uint gn = tile_n_start + n_local;

            // Pass 0: first Q8_0 block (k_base..k_base+31) for gate AND up.
            uint block_idx_0 = k_base / Q8B_GROUP_SIZE;
            // Pass 1: second Q8_0 block (k_base+32..k_base+63) for gate AND up.
            uint block_idx_1 = (k_base + 32) / Q8B_GROUP_SIZE;

            threadgroup half* sb_g_row_0 = sb_g + n_local * TILE_K_64 + k_offset;
            threadgroup half* sb_u_row_0 = sb_u + n_local * TILE_K_64 + k_offset;
            threadgroup half* sb_g_row_1 = sb_g + n_local * TILE_K_64 + 32 + k_offset;
            threadgroup half* sb_u_row_1 = sb_u + n_local * TILE_K_64 + 32 + k_offset;

            if (FC_BC_N || FC_BC_K) {
                // Gate, pass 0
                if (gn < N && k_base + k_offset < K) {
                    uint w_off = gn * row_bytes + block_idx_0 * Q8B_BLOCK_SIZE;
                    half scale_g = as_type<half>(*(device const ushort*)(W_gate + w_off));
                    device const char* qd_g = (device const char*)(W_gate + w_off + 2 + k_offset);
                    uint krem = K - (k_base + k_offset);
                    ushort cnt = (krem >= 8) ? 8 : (ushort)krem;
                    if (cnt == 8) {
                        sb_g_row_0[0] = scale_g * (half)qd_g[0];
                        sb_g_row_0[1] = scale_g * (half)qd_g[1];
                        sb_g_row_0[2] = scale_g * (half)qd_g[2];
                        sb_g_row_0[3] = scale_g * (half)qd_g[3];
                        sb_g_row_0[4] = scale_g * (half)qd_g[4];
                        sb_g_row_0[5] = scale_g * (half)qd_g[5];
                        sb_g_row_0[6] = scale_g * (half)qd_g[6];
                        sb_g_row_0[7] = scale_g * (half)qd_g[7];
                    } else {
                        for (ushort i = 0; i < cnt; i++) sb_g_row_0[i] = scale_g * (half)qd_g[i];
                        for (ushort i = cnt; i < 8; i++) sb_g_row_0[i] = (half)0.0h;
                    }
                } else {
                    FOR_UNROLL (ushort i = 0; i < 8; i++) sb_g_row_0[i] = (half)0.0h;
                }
                // Up, pass 0
                if (gn < N && k_base + k_offset < K) {
                    uint w_off = gn * row_bytes + block_idx_0 * Q8B_BLOCK_SIZE;
                    half scale_u = as_type<half>(*(device const ushort*)(W_up + w_off));
                    device const char* qd_u = (device const char*)(W_up + w_off + 2 + k_offset);
                    uint krem = K - (k_base + k_offset);
                    ushort cnt = (krem >= 8) ? 8 : (ushort)krem;
                    if (cnt == 8) {
                        sb_u_row_0[0] = scale_u * (half)qd_u[0];
                        sb_u_row_0[1] = scale_u * (half)qd_u[1];
                        sb_u_row_0[2] = scale_u * (half)qd_u[2];
                        sb_u_row_0[3] = scale_u * (half)qd_u[3];
                        sb_u_row_0[4] = scale_u * (half)qd_u[4];
                        sb_u_row_0[5] = scale_u * (half)qd_u[5];
                        sb_u_row_0[6] = scale_u * (half)qd_u[6];
                        sb_u_row_0[7] = scale_u * (half)qd_u[7];
                    } else {
                        for (ushort i = 0; i < cnt; i++) sb_u_row_0[i] = scale_u * (half)qd_u[i];
                        for (ushort i = cnt; i < 8; i++) sb_u_row_0[i] = (half)0.0h;
                    }
                } else {
                    FOR_UNROLL (ushort i = 0; i < 8; i++) sb_u_row_0[i] = (half)0.0h;
                }
                // Gate, pass 1
                if (gn < N && k_base + 32 + k_offset < K) {
                    uint w_off = gn * row_bytes + block_idx_1 * Q8B_BLOCK_SIZE;
                    half scale_g = as_type<half>(*(device const ushort*)(W_gate + w_off));
                    device const char* qd_g = (device const char*)(W_gate + w_off + 2 + k_offset);
                    uint krem = K - (k_base + 32 + k_offset);
                    ushort cnt = (krem >= 8) ? 8 : (ushort)krem;
                    if (cnt == 8) {
                        sb_g_row_1[0] = scale_g * (half)qd_g[0];
                        sb_g_row_1[1] = scale_g * (half)qd_g[1];
                        sb_g_row_1[2] = scale_g * (half)qd_g[2];
                        sb_g_row_1[3] = scale_g * (half)qd_g[3];
                        sb_g_row_1[4] = scale_g * (half)qd_g[4];
                        sb_g_row_1[5] = scale_g * (half)qd_g[5];
                        sb_g_row_1[6] = scale_g * (half)qd_g[6];
                        sb_g_row_1[7] = scale_g * (half)qd_g[7];
                    } else {
                        for (ushort i = 0; i < cnt; i++) sb_g_row_1[i] = scale_g * (half)qd_g[i];
                        for (ushort i = cnt; i < 8; i++) sb_g_row_1[i] = (half)0.0h;
                    }
                } else {
                    FOR_UNROLL (ushort i = 0; i < 8; i++) sb_g_row_1[i] = (half)0.0h;
                }
                // Up, pass 1
                if (gn < N && k_base + 32 + k_offset < K) {
                    uint w_off = gn * row_bytes + block_idx_1 * Q8B_BLOCK_SIZE;
                    half scale_u = as_type<half>(*(device const ushort*)(W_up + w_off));
                    device const char* qd_u = (device const char*)(W_up + w_off + 2 + k_offset);
                    uint krem = K - (k_base + 32 + k_offset);
                    ushort cnt = (krem >= 8) ? 8 : (ushort)krem;
                    if (cnt == 8) {
                        sb_u_row_1[0] = scale_u * (half)qd_u[0];
                        sb_u_row_1[1] = scale_u * (half)qd_u[1];
                        sb_u_row_1[2] = scale_u * (half)qd_u[2];
                        sb_u_row_1[3] = scale_u * (half)qd_u[3];
                        sb_u_row_1[4] = scale_u * (half)qd_u[4];
                        sb_u_row_1[5] = scale_u * (half)qd_u[5];
                        sb_u_row_1[6] = scale_u * (half)qd_u[6];
                        sb_u_row_1[7] = scale_u * (half)qd_u[7];
                    } else {
                        for (ushort i = 0; i < cnt; i++) sb_u_row_1[i] = scale_u * (half)qd_u[i];
                        for (ushort i = cnt; i < 8; i++) sb_u_row_1[i] = (half)0.0h;
                    }
                } else {
                    FOR_UNROLL (ushort i = 0; i < 8; i++) sb_u_row_1[i] = (half)0.0h;
                }
            } else {
                // Aligned fast path: no boundary checks.
                // Gate, pass 0
                {
                    uint w_off = gn * row_bytes + block_idx_0 * Q8B_BLOCK_SIZE;
                    half scale_g = as_type<half>(*(device const ushort*)(W_gate + w_off));
                    device const char* qd_g = (device const char*)(W_gate + w_off + 2 + k_offset);
                    sb_g_row_0[0] = scale_g * (half)qd_g[0];
                    sb_g_row_0[1] = scale_g * (half)qd_g[1];
                    sb_g_row_0[2] = scale_g * (half)qd_g[2];
                    sb_g_row_0[3] = scale_g * (half)qd_g[3];
                    sb_g_row_0[4] = scale_g * (half)qd_g[4];
                    sb_g_row_0[5] = scale_g * (half)qd_g[5];
                    sb_g_row_0[6] = scale_g * (half)qd_g[6];
                    sb_g_row_0[7] = scale_g * (half)qd_g[7];
                }
                // Up, pass 0
                {
                    uint w_off = gn * row_bytes + block_idx_0 * Q8B_BLOCK_SIZE;
                    half scale_u = as_type<half>(*(device const ushort*)(W_up + w_off));
                    device const char* qd_u = (device const char*)(W_up + w_off + 2 + k_offset);
                    sb_u_row_0[0] = scale_u * (half)qd_u[0];
                    sb_u_row_0[1] = scale_u * (half)qd_u[1];
                    sb_u_row_0[2] = scale_u * (half)qd_u[2];
                    sb_u_row_0[3] = scale_u * (half)qd_u[3];
                    sb_u_row_0[4] = scale_u * (half)qd_u[4];
                    sb_u_row_0[5] = scale_u * (half)qd_u[5];
                    sb_u_row_0[6] = scale_u * (half)qd_u[6];
                    sb_u_row_0[7] = scale_u * (half)qd_u[7];
                }
                // Gate, pass 1
                {
                    uint w_off = gn * row_bytes + block_idx_1 * Q8B_BLOCK_SIZE;
                    half scale_g = as_type<half>(*(device const ushort*)(W_gate + w_off));
                    device const char* qd_g = (device const char*)(W_gate + w_off + 2 + k_offset);
                    sb_g_row_1[0] = scale_g * (half)qd_g[0];
                    sb_g_row_1[1] = scale_g * (half)qd_g[1];
                    sb_g_row_1[2] = scale_g * (half)qd_g[2];
                    sb_g_row_1[3] = scale_g * (half)qd_g[3];
                    sb_g_row_1[4] = scale_g * (half)qd_g[4];
                    sb_g_row_1[5] = scale_g * (half)qd_g[5];
                    sb_g_row_1[6] = scale_g * (half)qd_g[6];
                    sb_g_row_1[7] = scale_g * (half)qd_g[7];
                }
                // Up, pass 1
                {
                    uint w_off = gn * row_bytes + block_idx_1 * Q8B_BLOCK_SIZE;
                    half scale_u = as_type<half>(*(device const ushort*)(W_up + w_off));
                    device const char* qd_u = (device const char*)(W_up + w_off + 2 + k_offset);
                    sb_u_row_1[0] = scale_u * (half)qd_u[0];
                    sb_u_row_1[1] = scale_u * (half)qd_u[1];
                    sb_u_row_1[2] = scale_u * (half)qd_u[2];
                    sb_u_row_1[3] = scale_u * (half)qd_u[3];
                    sb_u_row_1[4] = scale_u * (half)qd_u[4];
                    sb_u_row_1[5] = scale_u * (half)qd_u[5];
                    sb_u_row_1[6] = scale_u * (half)qd_u[6];
                    sb_u_row_1[7] = scale_u * (half)qd_u[7];
                }
            }
        }

        threadgroup_barrier(mem_flags::mem_threadgroup);

        // ---- MMA: accumulate BOTH gate and up outputs in parallel. ----
        // The A tile is read once and shared; B tiles are distinct (gate vs up).
        FOR_UNROLL (ushort ks = 0; ks < TILE_K_64; ks += 8) {
            simdgroup_half8x8 ma[2];
            simdgroup_barrier(mem_flags::mem_none);
            simdgroup_load(ma[0], sa + (sg_r * 16 + 0) * TILE_K_64 + ks, TILE_K_64);
            simdgroup_load(ma[1], sa + (sg_r * 16 + 8) * TILE_K_64 + ks, TILE_K_64);

            // Gate B tile.
            simdgroup_half8x8 mb_g[2];
            simdgroup_barrier(mem_flags::mem_none);
            simdgroup_load(mb_g[0], sb_g + (sg_c * 16 + 0) * TILE_K_64 + ks, TILE_K_64, ulong2(0,0), true);
            simdgroup_load(mb_g[1], sb_g + (sg_c * 16 + 8) * TILE_K_64 + ks, TILE_K_64, ulong2(0,0), true);

            simdgroup_barrier(mem_flags::mem_none);
            simdgroup_multiply_accumulate(mc_g[0][0], ma[0], mb_g[0], mc_g[0][0]);
            simdgroup_multiply_accumulate(mc_g[0][1], ma[0], mb_g[1], mc_g[0][1]);
            simdgroup_multiply_accumulate(mc_g[1][0], ma[1], mb_g[0], mc_g[1][0]);
            simdgroup_multiply_accumulate(mc_g[1][1], ma[1], mb_g[1], mc_g[1][1]);

            // Up B tile (re-uses ma loads above).
            simdgroup_half8x8 mb_u[2];
            simdgroup_barrier(mem_flags::mem_none);
            simdgroup_load(mb_u[0], sb_u + (sg_c * 16 + 0) * TILE_K_64 + ks, TILE_K_64, ulong2(0,0), true);
            simdgroup_load(mb_u[1], sb_u + (sg_c * 16 + 8) * TILE_K_64 + ks, TILE_K_64, ulong2(0,0), true);

            simdgroup_barrier(mem_flags::mem_none);
            simdgroup_multiply_accumulate(mc_u[0][0], ma[0], mb_u[0], mc_u[0][0]);
            simdgroup_multiply_accumulate(mc_u[0][1], ma[0], mb_u[1], mc_u[0][1]);
            simdgroup_multiply_accumulate(mc_u[1][0], ma[1], mb_u[0], mc_u[1][0]);
            simdgroup_multiply_accumulate(mc_u[1][1], ma[1], mb_u[1], mc_u[1][1]);
        }

        threadgroup_barrier(mem_flags::mem_threadgroup);
    }

    // ---- SwiGLU epilogue: store gate and up tiles to shmem, then read them
    // back as floats, apply silu(gate) * up, and write the activation to Y. ----
    //
    // We must use shmem scratch because simdgroup_store writes to the
    // accumulator's natural layout, and we need lane-friendly access to
    // both gate and up at the same (m, n) coordinate to apply SwiGLU.
    //
    // We reuse the 12 KB shmem region: it holds two float[16][16] per SG
    // (one each for gate and up), times 4 SGs = 8 * 256 floats = 2048 floats
    // = 8 KB. Fits in the 12 KB shmem we already declared (sa+sb_g+sb_u = 12 KB
    // = 6144 halfs = 3072 floats, so we have 12 KB / 2 = 6 KB float space for
    // one matrix; we need 8 KB total, so the layout is exactly:
    //   gate_sc: 8 KB = first 4 KB of sa+sb_g
    //   up_sc:   8 KB = next 4 KB of sb_g+sb_u
    // To stay simple and safe we cast shmem_gus to float and split it.

    threadgroup float* sc_gate = (threadgroup float*)shmem_gus;
    threadgroup float* sc_up   = (threadgroup float*)shmem_gus + 4 * 256;  // SGs gate * 256 floats
    threadgroup float* my_sc_gate = sc_gate + sgitg * 256;
    threadgroup float* my_sc_up   = sc_up   + sgitg * 256;

    FOR_UNROLL (ushort i = 0; i < 2; i++)
        FOR_UNROLL (ushort j = 0; j < 2; j++) {
            simdgroup_store(mc_g[i][j], my_sc_gate + (i * 8) * 16 + (j * 8), 16);
            simdgroup_store(mc_u[i][j], my_sc_up   + (i * 8) * 16 + (j * 8), 16);
        }
    threadgroup_barrier(mem_flags::mem_threadgroup);

    uint sg_m_base = tile_m_start + sg_r * 16;
    uint sg_n_base = tile_n_start + sg_c * 16;

    ushort lane = tiitg % 32;
    if (FC_BC_M || FC_BC_N) {
        for (ushort idx = lane; idx < 256; idx += 32) {
            ushort local_m = idx / 16;
            ushort local_n = idx % 16;
            uint gm = sg_m_base + local_m;
            uint gn = sg_n_base + local_n;
            if (gm < M && gn < N) {
                float g = my_sc_gate[local_m * 16 + local_n];
                float u = my_sc_up  [local_m * 16 + local_n];
                float sig = 1.0f / (1.0f + exp(-g));
                Y[gm * N + gn] = g * sig * u;
            }
        }
    } else {
        // Aligned fast path: skip per-thread bounds.
        for (ushort idx = lane; idx < 256; idx += 32) {
            ushort local_m = idx / 16;
            ushort local_n = idx % 16;
            uint gm = sg_m_base + local_m;
            uint gn = sg_n_base + local_n;
            float g = my_sc_gate[local_m * 16 + local_n];
            float u = my_sc_up  [local_m * 16 + local_n];
            float sig = 1.0f / (1.0f + exp(-g));
            Y[gm * N + gn] = g * sig * u;
        }
    }
}

// ============================================================================
// dequant_tiled_matmul_q8_0_splitk: Split-K variant for GPU core saturation
//
// Same computation as dequant_tiled_matmul_q8_0 but splits the K (reduction)
// dimension across multiple threadgroups via a 3D dispatch grid:
//   (ceil(N/TILE_N), ceil(M/TILE_M), k_splits)
//
// Each threadgroup computes a partial result for its K range, writing to
// Y_partial[split_idx * M * N + m * N + n]. A separate reduce_splitk kernel
// sums the partial results into the final output.
//
// This increases threadgroup count for small M*N GEMMs (e.g. pp128 with
// small models), saturating more GPU cores.
// ============================================================================

kernel void dequant_tiled_matmul_q8_0_splitk(
    device const uchar* W_q8     [[buffer(0)]],   // Q8_0 weights [N, K_bytes]
    device const float* X        [[buffer(1)]],   // [M, K] input batch
    device float*       Y_partial [[buffer(2)]],  // [k_splits, M, N] partial results
    constant uint&      M        [[buffer(3)]],   // batch size
    constant uint&      N        [[buffer(4)]],   // output dim
    constant uint&      K        [[buffer(5)]],   // input dim (elements)
    constant uint&      k_splits [[buffer(6)]],   // number of K splits
    uint3 tg_pos                 [[threadgroup_position_in_grid]],
    ushort tiitg                 [[thread_index_in_threadgroup]],
    ushort sgitg                 [[simdgroup_index_in_threadgroup]])
{
    threadgroup half shmem[2048];
    threadgroup half* sa = shmem;
    threadgroup half* sb = shmem + TILE_M * TILE_K;

    uint tile_n_start = tg_pos.x * TILE_N;
    uint tile_m_start = tg_pos.y * TILE_M;
    uint split_idx    = tg_pos.z;

    // Compute K range for this split, aligned to TILE_K (which equals Q8_0 group size)
    uint k_per_split = ((K + k_splits - 1) / k_splits);
    k_per_split = ((k_per_split + TILE_K - 1) / TILE_K) * TILE_K;
    uint k_start = split_idx * k_per_split;
    uint k_end = min(k_start + k_per_split, K);
    if (k_start >= K) {
        // This split has no work; zero its output tile
        uint partial_offset = split_idx * M * N;
        for (ushort idx = tiitg; idx < TILE_M * TILE_N; idx += TG_SIZE) {
            uint m_local = idx / TILE_N;
            uint n_local = idx % TILE_N;
            uint gm = tile_m_start + m_local;
            uint gn = tile_n_start + n_local;
            if (gm < M && gn < N)
                Y_partial[partial_offset + gm * N + gn] = 0.0f;
        }
        return;
    }

    ushort sg_r = sgitg / SG_COLS;
    ushort sg_c = sgitg % SG_COLS;

    simdgroup_float8x8 mc[2][2];
    FOR_UNROLL (ushort i = 0; i < 2; i++)
        FOR_UNROLL (ushort j = 0; j < 2; j++)
            mc[i][j] = make_filled_simdgroup_matrix<float, 8>(0.f);

    uint num_blocks_per_row = (K + Q8B_GROUP_SIZE - 1) / Q8B_GROUP_SIZE;
    uint row_bytes = num_blocks_per_row * Q8B_BLOCK_SIZE;

    uint first_kt = k_start / TILE_K;
    uint last_kt = (k_end + TILE_K - 1) / TILE_K;

    for (uint kt = first_kt; kt < last_kt; kt++) {
        uint k_base = kt * TILE_K;

        // Load A tile: vectorized 2D mapping, 4 threads per row, 8 elements each via float4
        // (Split-K variant: also checks gk is within [k_start, k_end) range)
        {
            ushort row = tiitg >> 2;           // tiitg / 4, range 0..31
            ushort col_group = tiitg & 3;      // tiitg % 4, range 0..3
            ushort k_local = col_group << 3;   // col_group * 8

            uint gm = tile_m_start + row;
            uint gk = k_base + k_local;
            threadgroup half* sa_ptr = sa + row * TILE_K + k_local;

            if (gm < M && gk + 7 < K && gk >= k_start && gk + 7 < k_end) {
                // Fast path: all 8 elements valid and within split range
                device const float4* x_ptr = (device const float4*)(X + gm * K + gk);
                float4 v0 = x_ptr[0];
                float4 v1 = x_ptr[1];
                sa_ptr[0] = (half)v0.x; sa_ptr[1] = (half)v0.y;
                sa_ptr[2] = (half)v0.z; sa_ptr[3] = (half)v0.w;
                sa_ptr[4] = (half)v1.x; sa_ptr[5] = (half)v1.y;
                sa_ptr[6] = (half)v1.z; sa_ptr[7] = (half)v1.w;
            } else {
                // Boundary: element-wise with full bounds check
                FOR_UNROLL (ushort i = 0; i < 8; i++) {
                    uint gk_i = gk + i;
                    sa_ptr[i] = (gm < M && gk_i < K && gk_i >= k_start && gk_i < k_end) ? (half)X[gm * K + gk_i] : (half)0.0h;
                }
            }
        }

        // Load B tile: vectorized Q8_0 dequant
        {
            uint block_idx = k_base / Q8B_GROUP_SIZE;
            ushort n_local = tiitg / 4;
            ushort t_in_row = tiitg % 4;
            ushort k_offset = t_in_row * 8;
            uint gn = tile_n_start + n_local;

            threadgroup half* sb_row = sb + n_local * TILE_K + k_offset;

            if (gn < N && k_base + k_offset < K && k_base + k_offset >= k_start && k_base + k_offset < k_end) {
                uint block_offset = gn * row_bytes + block_idx * Q8B_BLOCK_SIZE;
                half scale = as_type<half>(*(device const ushort*)(W_q8 + block_offset));
                device const char* qdata = (device const char*)(W_q8 + block_offset + 2 + k_offset);

                uint k_remaining = K - (k_base + k_offset);
                ushort count = (k_remaining >= 8) ? 8 : (ushort)k_remaining;

                if (count == 8) {
                    sb_row[0] = scale * (half)qdata[0];
                    sb_row[1] = scale * (half)qdata[1];
                    sb_row[2] = scale * (half)qdata[2];
                    sb_row[3] = scale * (half)qdata[3];
                    sb_row[4] = scale * (half)qdata[4];
                    sb_row[5] = scale * (half)qdata[5];
                    sb_row[6] = scale * (half)qdata[6];
                    sb_row[7] = scale * (half)qdata[7];
                } else {
                    for (ushort i = 0; i < count; i++) {
                        sb_row[i] = scale * (half)qdata[i];
                    }
                    for (ushort i = count; i < 8; i++) {
                        sb_row[i] = (half)0.0h;
                    }
                }
            } else {
                FOR_UNROLL (ushort i = 0; i < 8; i++) {
                    sb_row[i] = (half)0.0h;
                }
            }
        }

        threadgroup_barrier(mem_flags::mem_threadgroup);

        // MMA
        FOR_UNROLL (ushort ks = 0; ks < TILE_K; ks += 8) {
            simdgroup_half8x8 ma[2];
            simdgroup_barrier(mem_flags::mem_none);
            simdgroup_load(ma[0], sa + (sg_r * 16 + 0) * TILE_K + ks, TILE_K);
            simdgroup_load(ma[1], sa + (sg_r * 16 + 8) * TILE_K + ks, TILE_K);

            simdgroup_half8x8 mb[2];
            simdgroup_barrier(mem_flags::mem_none);
            simdgroup_load(mb[0], sb + (sg_c * 16 + 0) * TILE_K + ks, TILE_K, ulong2(0,0), true);
            simdgroup_load(mb[1], sb + (sg_c * 16 + 8) * TILE_K + ks, TILE_K, ulong2(0,0), true);

            simdgroup_barrier(mem_flags::mem_none);
            simdgroup_multiply_accumulate(mc[0][0], ma[0], mb[0], mc[0][0]);
            simdgroup_multiply_accumulate(mc[0][1], ma[0], mb[1], mc[0][1]);
            simdgroup_multiply_accumulate(mc[1][0], ma[1], mb[0], mc[1][0]);
            simdgroup_multiply_accumulate(mc[1][1], ma[1], mb[1], mc[1][1]);
        }

        threadgroup_barrier(mem_flags::mem_threadgroup);
    }

    // Store to partial buffer at offset split_idx * M * N
    uint partial_offset = split_idx * M * N;
    uint sg_m_base = tile_m_start + sg_r * 16;
    uint sg_n_base = tile_n_start + sg_c * 16;

    if (sg_m_base + 16 <= M && sg_n_base + 16 <= N) {
        FOR_UNROLL (ushort i = 0; i < 2; i++)
            FOR_UNROLL (ushort j = 0; j < 2; j++)
                simdgroup_store(mc[i][j], Y_partial + partial_offset + (sg_m_base + i * 8) * N + (sg_n_base + j * 8), N);
    } else {
        threadgroup float* sc = (threadgroup float*)shmem;
        threadgroup float* my_sc = sc + sgitg * 256;
        FOR_UNROLL (ushort i = 0; i < 2; i++)
            FOR_UNROLL (ushort j = 0; j < 2; j++)
                simdgroup_store(mc[i][j], my_sc + (i * 8) * 16 + (j * 8), 16);
        threadgroup_barrier(mem_flags::mem_threadgroup);
        ushort lane = tiitg % 32;
        for (ushort idx = lane; idx < 256; idx += 32) {
            ushort local_m = idx / 16;
            ushort local_n = idx % 16;
            uint gm = sg_m_base + local_m;
            uint gn = sg_n_base + local_n;
            if (gm < M && gn < N) {
                Y_partial[partial_offset + gm * N + gn] = my_sc[local_m * 16 + local_n];
            }
        }
    }
}

// ============================================================================
// reduce_splitk: Sum partial results from Split-K GEMM
//
// partials: [k_splits, M, N] -- partial sums from each split
// output:   [M, N] -- final result
//
// Simple element-wise reduction: output[i] = sum(partials[s * M*N + i])
// ============================================================================

kernel void reduce_splitk(
    device const float* partials  [[buffer(0)]],
    device float*       output    [[buffer(1)]],
    constant uint&      M         [[buffer(2)]],
    constant uint&      N         [[buffer(3)]],
    constant uint&      k_splits  [[buffer(4)]],
    uint gid                      [[thread_position_in_grid]])
{
    uint total = M * N;
    if (gid >= total) return;

    float sum = 0.0f;
    for (uint s = 0; s < k_splits; s++) {
        sum += partials[s * total + gid];
    }
    output[gid] = sum;
}

// ============================================================================
// dequant_tiled_matmul_q8_0_k64_splitk: Split-K variant on the K64 path
//
// Same as dequant_tiled_matmul_q8_0_splitk but uses TILE_K_64=64 to halve the
// load barrier count vs TILE_K=32. Targets FFN-down geometry (K large, M small,
// N moderate) where 2D tile grid does not saturate the GPU.
//
// Grid: (ceil(N/TILE_N), ceil(M/TILE_M), k_splits)
// Each TG writes to Y_partial[split_idx * M * N + m * N + n] for its K range.
// k_per_split is rounded up to a multiple of TILE_K_64 (= 64).
//
// Designed to be paired with reduce_splitk_add_residual to write
//   Y[m,n] = sum_s(Y_partial[s,m,n]) + R[m,n]
// in a single output pass.
// ============================================================================

kernel void dequant_tiled_matmul_q8_0_k64_splitk(
    device const uchar* W_q8     [[buffer(0)]],   // Q8_0 weights [N, K_bytes]
    device const float* X        [[buffer(1)]],   // [M, K] input batch
    device float*       Y_partial [[buffer(2)]],  // [k_splits, M, N] partial results
    constant uint&      M        [[buffer(3)]],   // batch size
    constant uint&      N        [[buffer(4)]],   // output dim
    constant uint&      K        [[buffer(5)]],   // input dim (elements)
    constant uint&      k_splits [[buffer(6)]],   // number of K splits
    uint3 tg_pos                 [[threadgroup_position_in_grid]],
    ushort tiitg                 [[thread_index_in_threadgroup]],
    ushort sgitg                 [[simdgroup_index_in_threadgroup]])
{
    threadgroup half shmem_sp[4096];
    threadgroup half* sa = shmem_sp;
    threadgroup half* sb = shmem_sp + TILE_M * TILE_K_64;

    uint tile_n_start = tg_pos.x * TILE_N;
    uint tile_m_start = tg_pos.y * TILE_M;
    uint split_idx    = tg_pos.z;

    // K range for this split: aligned to TILE_K_64 (64-element multiples).
    uint k_per_split = ((K + k_splits - 1) / k_splits);
    k_per_split = ((k_per_split + TILE_K_64 - 1) / TILE_K_64) * TILE_K_64;
    uint k_start = split_idx * k_per_split;
    uint k_end = min(k_start + k_per_split, K);
    if (k_start >= K) {
        // No work for this split: zero its output tile so reduce sees zero.
        uint partial_offset = split_idx * M * N;
        for (ushort idx = tiitg; idx < TILE_M * TILE_N; idx += TG_SIZE) {
            uint m_local = idx / TILE_N;
            uint n_local = idx % TILE_N;
            uint gm = tile_m_start + m_local;
            uint gn = tile_n_start + n_local;
            if (gm < M && gn < N)
                Y_partial[partial_offset + gm * N + gn] = 0.0f;
        }
        return;
    }

    ushort sg_r = sgitg / SG_COLS;
    ushort sg_c = sgitg % SG_COLS;

    simdgroup_float8x8 mc[2][2];
    FOR_UNROLL (ushort i = 0; i < 2; i++)
        FOR_UNROLL (ushort j = 0; j < 2; j++)
            mc[i][j] = make_filled_simdgroup_matrix<float, 8>(0.f);

    uint num_blocks_per_row = (K + Q8B_GROUP_SIZE - 1) / Q8B_GROUP_SIZE;
    uint row_bytes = num_blocks_per_row * Q8B_BLOCK_SIZE;

    uint first_kt = k_start / TILE_K_64;
    uint last_kt = (k_end + TILE_K_64 - 1) / TILE_K_64;

    for (uint kt = first_kt; kt < last_kt; kt++) {
        uint k_base = kt * TILE_K_64;

        // --- Load A tile: 32 rows x 64 cols, 4 threads per row, 16 elements each. ---
        {
            ushort row = tiitg >> 2;
            ushort col_group = tiitg & 3;
            ushort k_local = col_group << 4;          // col_group * 16

            uint gm = tile_m_start + row;
            uint gk = k_base + k_local;
            threadgroup half* sa_ptr = sa + row * TILE_K_64 + k_local;

            if (gm < M && gk + 15 < K && gk >= k_start && gk + 15 < k_end) {
                device const float4* x_ptr = (device const float4*)(X + gm * K + gk);
                float4 v0 = x_ptr[0];
                float4 v1 = x_ptr[1];
                float4 v2 = x_ptr[2];
                float4 v3 = x_ptr[3];
                sa_ptr[0]  = (half)v0.x; sa_ptr[1]  = (half)v0.y;
                sa_ptr[2]  = (half)v0.z; sa_ptr[3]  = (half)v0.w;
                sa_ptr[4]  = (half)v1.x; sa_ptr[5]  = (half)v1.y;
                sa_ptr[6]  = (half)v1.z; sa_ptr[7]  = (half)v1.w;
                sa_ptr[8]  = (half)v2.x; sa_ptr[9]  = (half)v2.y;
                sa_ptr[10] = (half)v2.z; sa_ptr[11] = (half)v2.w;
                sa_ptr[12] = (half)v3.x; sa_ptr[13] = (half)v3.y;
                sa_ptr[14] = (half)v3.z; sa_ptr[15] = (half)v3.w;
            } else {
                FOR_UNROLL (ushort i = 0; i < 16; i++) {
                    uint gk_i = gk + i;
                    sa_ptr[i] = (gm < M && gk_i < K && gk_i >= k_start && gk_i < k_end)
                        ? (half)X[gm * K + gk_i]
                        : (half)0.0h;
                }
            }
        }

        // --- Load B tile: 2-pass Q8_0 dequant (two 32-element blocks per row). ---
        {
            ushort n_local = tiitg >> 2;
            ushort t_in_row = tiitg & 3;
            uint gn = tile_n_start + n_local;

            // Pass 0: first block (k_base + 0..31)
            {
                uint block_idx = k_base / Q8B_GROUP_SIZE;
                ushort k_offset = t_in_row * 8;
                threadgroup half* sb_row = sb + n_local * TILE_K_64 + k_offset;

                bool in_range = (gn < N
                              && k_base + k_offset < K
                              && k_base + k_offset >= k_start
                              && k_base + k_offset < k_end);
                if (in_range) {
                    uint block_offset = gn * row_bytes + block_idx * Q8B_BLOCK_SIZE;
                    half scale = as_type<half>(*(device const ushort*)(W_q8 + block_offset));
                    device const char* qdata = (device const char*)(W_q8 + block_offset + 2 + k_offset);

                    uint k_remaining = K - (k_base + k_offset);
                    ushort count = (k_remaining >= 8) ? 8 : (ushort)k_remaining;
                    if (count == 8) {
                        sb_row[0] = scale * (half)qdata[0];
                        sb_row[1] = scale * (half)qdata[1];
                        sb_row[2] = scale * (half)qdata[2];
                        sb_row[3] = scale * (half)qdata[3];
                        sb_row[4] = scale * (half)qdata[4];
                        sb_row[5] = scale * (half)qdata[5];
                        sb_row[6] = scale * (half)qdata[6];
                        sb_row[7] = scale * (half)qdata[7];
                    } else {
                        for (ushort i = 0; i < count; i++) {
                            sb_row[i] = scale * (half)qdata[i];
                        }
                        for (ushort i = count; i < 8; i++) {
                            sb_row[i] = (half)0.0h;
                        }
                    }
                } else {
                    FOR_UNROLL (ushort i = 0; i < 8; i++) {
                        sb_row[i] = (half)0.0h;
                    }
                }
            }

            // Pass 1: second block (k_base + 32..63)
            {
                uint block_idx = (k_base + 32) / Q8B_GROUP_SIZE;
                ushort k_offset = t_in_row * 8;
                threadgroup half* sb_row = sb + n_local * TILE_K_64 + 32 + k_offset;

                bool in_range = (gn < N
                              && k_base + 32 + k_offset < K
                              && k_base + 32 + k_offset >= k_start
                              && k_base + 32 + k_offset < k_end);
                if (in_range) {
                    uint block_offset = gn * row_bytes + block_idx * Q8B_BLOCK_SIZE;
                    half scale = as_type<half>(*(device const ushort*)(W_q8 + block_offset));
                    device const char* qdata = (device const char*)(W_q8 + block_offset + 2 + k_offset);

                    uint k_remaining = K - (k_base + 32 + k_offset);
                    ushort count = (k_remaining >= 8) ? 8 : (ushort)k_remaining;
                    if (count == 8) {
                        sb_row[0] = scale * (half)qdata[0];
                        sb_row[1] = scale * (half)qdata[1];
                        sb_row[2] = scale * (half)qdata[2];
                        sb_row[3] = scale * (half)qdata[3];
                        sb_row[4] = scale * (half)qdata[4];
                        sb_row[5] = scale * (half)qdata[5];
                        sb_row[6] = scale * (half)qdata[6];
                        sb_row[7] = scale * (half)qdata[7];
                    } else {
                        for (ushort i = 0; i < count; i++) {
                            sb_row[i] = scale * (half)qdata[i];
                        }
                        for (ushort i = count; i < 8; i++) {
                            sb_row[i] = (half)0.0h;
                        }
                    }
                } else {
                    FOR_UNROLL (ushort i = 0; i < 8; i++) {
                        sb_row[i] = (half)0.0h;
                    }
                }
            }
        }

        threadgroup_barrier(mem_flags::mem_threadgroup);

        // MMA: same as K64 path (8 simdgroup_multiply_accumulate per kt).
        FOR_UNROLL (ushort ks = 0; ks < TILE_K_64; ks += 8) {
            simdgroup_half8x8 ma[2];
            simdgroup_barrier(mem_flags::mem_none);
            simdgroup_load(ma[0], sa + (sg_r * 16 + 0) * TILE_K_64 + ks, TILE_K_64);
            simdgroup_load(ma[1], sa + (sg_r * 16 + 8) * TILE_K_64 + ks, TILE_K_64);

            simdgroup_half8x8 mb[2];
            simdgroup_barrier(mem_flags::mem_none);
            simdgroup_load(mb[0], sb + (sg_c * 16 + 0) * TILE_K_64 + ks, TILE_K_64, ulong2(0,0), true);
            simdgroup_load(mb[1], sb + (sg_c * 16 + 8) * TILE_K_64 + ks, TILE_K_64, ulong2(0,0), true);

            simdgroup_barrier(mem_flags::mem_none);
            simdgroup_multiply_accumulate(mc[0][0], ma[0], mb[0], mc[0][0]);
            simdgroup_multiply_accumulate(mc[0][1], ma[0], mb[1], mc[0][1]);
            simdgroup_multiply_accumulate(mc[1][0], ma[1], mb[0], mc[1][0]);
            simdgroup_multiply_accumulate(mc[1][1], ma[1], mb[1], mc[1][1]);
        }

        threadgroup_barrier(mem_flags::mem_threadgroup);
    }

    // Store to partial buffer at offset split_idx * M * N (no residual; reduce handles it).
    uint partial_offset = split_idx * M * N;
    uint sg_m_base = tile_m_start + sg_r * 16;
    uint sg_n_base = tile_n_start + sg_c * 16;

    if (sg_m_base + 16 <= M && sg_n_base + 16 <= N) {
        FOR_UNROLL (ushort i = 0; i < 2; i++)
            FOR_UNROLL (ushort j = 0; j < 2; j++)
                simdgroup_store(mc[i][j], Y_partial + partial_offset + (sg_m_base + i * 8) * N + (sg_n_base + j * 8), N);
    } else {
        threadgroup float* sc = (threadgroup float*)shmem_sp;
        threadgroup float* my_sc = sc + sgitg * 256;
        FOR_UNROLL (ushort i = 0; i < 2; i++)
            FOR_UNROLL (ushort j = 0; j < 2; j++)
                simdgroup_store(mc[i][j], my_sc + (i * 8) * 16 + (j * 8), 16);
        threadgroup_barrier(mem_flags::mem_threadgroup);
        ushort lane = tiitg % 32;
        for (ushort idx = lane; idx < 256; idx += 32) {
            ushort local_m = idx / 16;
            ushort local_n = idx % 16;
            uint gm = sg_m_base + local_m;
            uint gn = sg_n_base + local_n;
            if (gm < M && gn < N) {
                Y_partial[partial_offset + gm * N + gn] = my_sc[local_m * 16 + local_n];
            }
        }
    }
}

// ============================================================================
// reduce_splitk_add_residual: Sum partial results + residual into final Y.
//
// partials: [k_splits, M, N] partial sums
// R       : [M, N] residual (e.g. attn_proj for FFN-down)
// output  : [M, N] = sum_s(partials[s]) + R
//
// One pass writeback (replaces separate add_write kernel after reduce_splitk).
// ============================================================================

kernel void reduce_splitk_add_residual(
    device const float* partials  [[buffer(0)]],
    device const float* R         [[buffer(1)]],
    device float*       output    [[buffer(2)]],
    constant uint&      M         [[buffer(3)]],
    constant uint&      N         [[buffer(4)]],
    constant uint&      k_splits  [[buffer(5)]],
    uint gid                      [[thread_position_in_grid]])
{
    uint total = M * N;
    if (gid >= total) return;

    float sum = R[gid];
    for (uint s = 0; s < k_splits; s++) {
        sum += partials[s * total + gid];
    }
    output[gid] = sum;
}

// ============================================================================
// Packed-layout Q8_0 GEMM kernels
//
// These kernels are bit-identical to their AoS counterparts (no precision
// loss, same FMA order, same simdgroup MMA path) but consume a repacked
// weight buffer in a stripe SoA layout (see `metal/repack_q8.rs`):
//
//   For each (row_group=gn/32, k_block=k_offset/32), the packed layout is
//   a contiguous 1088-byte block:
//
//     bytes [   0..  64]: 32 × f16 scales  (one per row in the row-group)
//     bytes [  64..1088]: 32 × 32-byte qdata (row-major within the group)
//
//   stripe_stride = (K / 32) * 1088
//   block_base    = row_group * stripe_stride + k_block * 1088
//   scale_for_row = block_base + (row_in_group) * 2
//   qdata_for_row = block_base + 64 + (row_in_group) * 32
//
// Why repack: the original AoS kernel (gemm_q8_0.msl:473) reads 4 threads
// per row-block, each fetching its own 2-byte scale (4× redundant scale
// fetches). With SoA, the 32 scales for a row-group sit on a 64-byte
// contiguous segment — Apple AGX coalesces these into a single 128-byte
// L1 line transfer regardless of thread arbitration, removing the
// redundancy.
//
// The kernel structure (TG geometry, MMA loops, residual writeback,
// FC_BC_M/N/K function constants) is unchanged from the AoS K64 variant.
// Only the index arithmetic for the B-side load changes.
// ============================================================================

// ----------------------------------------------------------------------------
// dequant_tiled_matmul_q8_0_k64_residual_batched_packed
//
// Same algorithm as `dequant_tiled_matmul_q8_0_k64_residual_batched` but
// reads weights from the packed stripe layout. Used for FFN-down.
// ----------------------------------------------------------------------------

kernel void dequant_tiled_matmul_q8_0_k64_residual_batched_packed(
    device const uchar* W_q8     [[buffer(0)]],   // Packed Q8_0 weights, stripe SoA
    device const float* X        [[buffer(1)]],   // [M, K] input batch
    device float*       Y        [[buffer(2)]],   // [M, N] output batch
    constant uint&      M        [[buffer(3)]],
    constant uint&      N        [[buffer(4)]],
    constant uint&      K        [[buffer(5)]],
    device const float* R        [[buffer(6)]],   // [M, N] residual to add
    uint2 tg_pos                 [[threadgroup_position_in_grid]],
    ushort tiitg                 [[thread_index_in_threadgroup]],
    ushort sgitg                 [[simdgroup_index_in_threadgroup]])
{
    threadgroup half shmem_k64rp[4096];
    threadgroup half* sa = shmem_k64rp;
    threadgroup half* sb = shmem_k64rp + TILE_M * TILE_K_64;

    uint tile_m_start = tg_pos.y * TILE_M;
    uint tile_n_start = tg_pos.x * TILE_N;

    ushort sg_r = sgitg / SG_COLS;
    ushort sg_c = sgitg % SG_COLS;

    simdgroup_float8x8 mc[2][2];
    FOR_UNROLL (ushort i = 0; i < 2; i++)
        FOR_UNROLL (ushort j = 0; j < 2; j++)
            mc[i][j] = make_filled_simdgroup_matrix<float, 8>(0.f);

    // Packed layout parameters
    uint num_blocks_per_row = (K + Q8B_GROUP_SIZE - 1) / Q8B_GROUP_SIZE;
    // stripe_stride (bytes) = num_blocks_per_row * 1088
    uint stripe_stride = num_blocks_per_row * 1088u;

    uint num_k_tiles = (K + TILE_K_64 - 1) / TILE_K_64;

    // Pre-compute the row-group for this tile's N range.
    // tile_n_start is always a multiple of TILE_N=32, so it maps to one
    // row-group (row_group = tile_n_start / 32). The row-group base is the
    // same for all threads in the threadgroup, since all 32 output rows in
    // this tile share the same row_group.
    uint row_group = tile_n_start / 32u;
    uint rg_base = row_group * stripe_stride;

    for (uint kt = 0; kt < num_k_tiles; kt++) {
        uint k_base = kt * TILE_K_64;

        // ---- Load A tile (X): identical to AoS k64_residual_batched. ----
        {
            ushort row = tiitg >> 2;
            ushort col_group = tiitg & 3;
            ushort k_start = col_group << 4;

            uint gm = tile_m_start + row;
            uint gk = k_base + k_start;
            threadgroup half* sa_ptr = sa + row * TILE_K_64 + k_start;

            if (FC_BC_M || FC_BC_K) {
                if (gm < M && gk + 15 < K) {
                    device const float4* x_ptr = (device const float4*)(X + gm * K + gk);
                    float4 v0 = x_ptr[0];
                    float4 v1 = x_ptr[1];
                    float4 v2 = x_ptr[2];
                    float4 v3 = x_ptr[3];
                    sa_ptr[0]  = (half)v0.x; sa_ptr[1]  = (half)v0.y;
                    sa_ptr[2]  = (half)v0.z; sa_ptr[3]  = (half)v0.w;
                    sa_ptr[4]  = (half)v1.x; sa_ptr[5]  = (half)v1.y;
                    sa_ptr[6]  = (half)v1.z; sa_ptr[7]  = (half)v1.w;
                    sa_ptr[8]  = (half)v2.x; sa_ptr[9]  = (half)v2.y;
                    sa_ptr[10] = (half)v2.z; sa_ptr[11] = (half)v2.w;
                    sa_ptr[12] = (half)v3.x; sa_ptr[13] = (half)v3.y;
                    sa_ptr[14] = (half)v3.z; sa_ptr[15] = (half)v3.w;
                } else {
                    FOR_UNROLL (ushort i = 0; i < 16; i++) {
                        uint gk_i = gk + i;
                        sa_ptr[i] = (gm < M && gk_i < K) ? (half)X[gm * K + gk_i] : (half)0.0h;
                    }
                }
            } else {
                device const float4* x_ptr = (device const float4*)(X + gm * K + gk);
                float4 v0 = x_ptr[0];
                float4 v1 = x_ptr[1];
                float4 v2 = x_ptr[2];
                float4 v3 = x_ptr[3];
                sa_ptr[0]  = (half)v0.x; sa_ptr[1]  = (half)v0.y;
                sa_ptr[2]  = (half)v0.z; sa_ptr[3]  = (half)v0.w;
                sa_ptr[4]  = (half)v1.x; sa_ptr[5]  = (half)v1.y;
                sa_ptr[6]  = (half)v1.z; sa_ptr[7]  = (half)v1.w;
                sa_ptr[8]  = (half)v2.x; sa_ptr[9]  = (half)v2.y;
                sa_ptr[10] = (half)v2.z; sa_ptr[11] = (half)v2.w;
                sa_ptr[12] = (half)v3.x; sa_ptr[13] = (half)v3.y;
                sa_ptr[14] = (half)v3.z; sa_ptr[15] = (half)v3.w;
            }
        }

        // ---- Load B tile from PACKED layout: 32 rows × 64 cols (2 k-blocks) ----
        {
            ushort n_local = tiitg >> 2;       // 0..31 (which row in row-group)
            ushort t_in_row = tiitg & 3;       // 0..3 (which quarter of 32 k-elements)
            ushort k_offset = t_in_row * 8;
            uint gn = tile_n_start + n_local;

            // Pass 0: first Q8_0 block (k_base + 0..31)
            {
                uint block_idx_0 = k_base / Q8B_GROUP_SIZE;
                uint block_base_0 = rg_base + block_idx_0 * 1088u;
                threadgroup half* sb_row = sb + n_local * TILE_K_64 + k_offset;

                if (FC_BC_N || FC_BC_K) {
                    if (gn < N && k_base + k_offset < K) {
                        // Scale: bytes [block_base_0 + n_local*2 .. +2]
                        half scale = as_type<half>(*(device const ushort*)(W_q8 + block_base_0 + n_local * 2u));
                        // Qdata: bytes [block_base_0 + 64 + n_local*32 + k_offset .. +8]
                        device const char* qdata = (device const char*)(W_q8 + block_base_0 + 64u + n_local * 32u + k_offset);

                        uint k_remaining = K - (k_base + k_offset);
                        ushort count = (k_remaining >= 8) ? 8 : (ushort)k_remaining;

                        if (count == 8) {
                            sb_row[0] = scale * (half)qdata[0];
                            sb_row[1] = scale * (half)qdata[1];
                            sb_row[2] = scale * (half)qdata[2];
                            sb_row[3] = scale * (half)qdata[3];
                            sb_row[4] = scale * (half)qdata[4];
                            sb_row[5] = scale * (half)qdata[5];
                            sb_row[6] = scale * (half)qdata[6];
                            sb_row[7] = scale * (half)qdata[7];
                        } else {
                            for (ushort i = 0; i < count; i++) {
                                sb_row[i] = scale * (half)qdata[i];
                            }
                            for (ushort i = count; i < 8; i++) {
                                sb_row[i] = (half)0.0h;
                            }
                        }
                    } else {
                        FOR_UNROLL (ushort i = 0; i < 8; i++) sb_row[i] = (half)0.0h;
                    }
                } else {
                    half scale = as_type<half>(*(device const ushort*)(W_q8 + block_base_0 + n_local * 2u));
                    device const char* qdata = (device const char*)(W_q8 + block_base_0 + 64u + n_local * 32u + k_offset);
                    sb_row[0] = scale * (half)qdata[0];
                    sb_row[1] = scale * (half)qdata[1];
                    sb_row[2] = scale * (half)qdata[2];
                    sb_row[3] = scale * (half)qdata[3];
                    sb_row[4] = scale * (half)qdata[4];
                    sb_row[5] = scale * (half)qdata[5];
                    sb_row[6] = scale * (half)qdata[6];
                    sb_row[7] = scale * (half)qdata[7];
                }
            }

            // Pass 1: second Q8_0 block (k_base + 32..63)
            {
                uint block_idx_1 = (k_base + 32) / Q8B_GROUP_SIZE;
                uint block_base_1 = rg_base + block_idx_1 * 1088u;
                threadgroup half* sb_row = sb + n_local * TILE_K_64 + 32 + k_offset;

                if (FC_BC_N || FC_BC_K) {
                    if (gn < N && k_base + 32 + k_offset < K) {
                        half scale = as_type<half>(*(device const ushort*)(W_q8 + block_base_1 + n_local * 2u));
                        device const char* qdata = (device const char*)(W_q8 + block_base_1 + 64u + n_local * 32u + k_offset);

                        uint k_remaining = K - (k_base + 32 + k_offset);
                        ushort count = (k_remaining >= 8) ? 8 : (ushort)k_remaining;

                        if (count == 8) {
                            sb_row[0] = scale * (half)qdata[0];
                            sb_row[1] = scale * (half)qdata[1];
                            sb_row[2] = scale * (half)qdata[2];
                            sb_row[3] = scale * (half)qdata[3];
                            sb_row[4] = scale * (half)qdata[4];
                            sb_row[5] = scale * (half)qdata[5];
                            sb_row[6] = scale * (half)qdata[6];
                            sb_row[7] = scale * (half)qdata[7];
                        } else {
                            for (ushort i = 0; i < count; i++) {
                                sb_row[i] = scale * (half)qdata[i];
                            }
                            for (ushort i = count; i < 8; i++) {
                                sb_row[i] = (half)0.0h;
                            }
                        }
                    } else {
                        FOR_UNROLL (ushort i = 0; i < 8; i++) sb_row[i] = (half)0.0h;
                    }
                } else {
                    half scale = as_type<half>(*(device const ushort*)(W_q8 + block_base_1 + n_local * 2u));
                    device const char* qdata = (device const char*)(W_q8 + block_base_1 + 64u + n_local * 32u + k_offset);
                    sb_row[0] = scale * (half)qdata[0];
                    sb_row[1] = scale * (half)qdata[1];
                    sb_row[2] = scale * (half)qdata[2];
                    sb_row[3] = scale * (half)qdata[3];
                    sb_row[4] = scale * (half)qdata[4];
                    sb_row[5] = scale * (half)qdata[5];
                    sb_row[6] = scale * (half)qdata[6];
                    sb_row[7] = scale * (half)qdata[7];
                }
            }
        }

        threadgroup_barrier(mem_flags::mem_threadgroup);

        // ---- MMA: same as AoS K64 path. ----
        FOR_UNROLL (ushort ks = 0; ks < TILE_K_64; ks += 8) {
            simdgroup_half8x8 ma[2];
            simdgroup_barrier(mem_flags::mem_none);
            simdgroup_load(ma[0], sa + (sg_r * 16 + 0) * TILE_K_64 + ks, TILE_K_64);
            simdgroup_load(ma[1], sa + (sg_r * 16 + 8) * TILE_K_64 + ks, TILE_K_64);

            simdgroup_half8x8 mb[2];
            simdgroup_barrier(mem_flags::mem_none);
            simdgroup_load(mb[0], sb + (sg_c * 16 + 0) * TILE_K_64 + ks, TILE_K_64, ulong2(0,0), true);
            simdgroup_load(mb[1], sb + (sg_c * 16 + 8) * TILE_K_64 + ks, TILE_K_64, ulong2(0,0), true);

            simdgroup_barrier(mem_flags::mem_none);
            simdgroup_multiply_accumulate(mc[0][0], ma[0], mb[0], mc[0][0]);
            simdgroup_multiply_accumulate(mc[0][1], ma[0], mb[1], mc[0][1]);
            simdgroup_multiply_accumulate(mc[1][0], ma[1], mb[0], mc[1][0]);
            simdgroup_multiply_accumulate(mc[1][1], ma[1], mb[1], mc[1][1]);
        }

        threadgroup_barrier(mem_flags::mem_threadgroup);
    }

    // ---- Residual writeback: identical to AoS K64 path. ----
    uint sg_m_base = tile_m_start + sg_r * 16;
    uint sg_n_base = tile_n_start + sg_c * 16;

    {
        threadgroup float* sc = (threadgroup float*)shmem_k64rp;
        threadgroup float* my_sc = sc + sgitg * 256;
        FOR_UNROLL (ushort i = 0; i < 2; i++)
            FOR_UNROLL (ushort j = 0; j < 2; j++)
                simdgroup_store(mc[i][j], my_sc + (i * 8) * 16 + (j * 8), 16);
        threadgroup_barrier(mem_flags::mem_threadgroup);
        ushort lane = tiitg % 32;
        if (FC_BC_M || FC_BC_N) {
            for (ushort idx = lane; idx < 256; idx += 32) {
                ushort local_m = idx / 16;
                ushort local_n = idx % 16;
                uint gm = sg_m_base + local_m;
                uint gn = sg_n_base + local_n;
                if (gm < M && gn < N) {
                    Y[gm * N + gn] = my_sc[local_m * 16 + local_n] + R[gm * N + gn];
                }
            }
        } else {
            for (ushort idx = lane; idx < 256; idx += 32) {
                ushort local_m = idx / 16;
                ushort local_n = idx % 16;
                uint gm = sg_m_base + local_m;
                uint gn = sg_n_base + local_n;
                Y[gm * N + gn] = my_sc[local_m * 16 + local_n] + R[gm * N + gn];
            }
        }
    }
}

// ----------------------------------------------------------------------------
// dequant_tiled_matmul_q8_0_gate_up_swiglu_fused_packed
//
// Same algorithm as `dequant_tiled_matmul_q8_0_gate_up_swiglu_fused` but
// reads gate and up weights from a single pair-packed buffer (see
// `repack_q8_pair_gate_up` in repack_q8.rs). Layout per (row_group, k_block):
//
//     bytes [   0..  64]: gate scales (32 × f16)
//     bytes [  64.. 128]: up scales   (32 × f16)
//     bytes [ 128..1152]: gate qdata  (32 × 32 = 1024 bytes)
//     bytes [1152..2176]: up qdata    (32 × 32 = 1024 bytes)
//
//   stripe_stride = (K / 32) * 2176
//   block_base    = row_group * stripe_stride + k_block * 2176
//   gate_scale    = block_base + (row_in_group) * 2
//   up_scale      = block_base + 64 + (row_in_group) * 2
//   gate_qdata    = block_base + 128 + (row_in_group) * 32
//   up_qdata      = block_base + 1152 + (row_in_group) * 32
//
// One buffer replaces two distinct W_gate + W_up buffers, halving the
// number of memory streams the fused kernel reads.
// ----------------------------------------------------------------------------

kernel void dequant_tiled_matmul_q8_0_gate_up_swiglu_fused_packed(
    device const uchar* W_gate_up [[buffer(0)]],  // Paired packed Q8_0 weights
    device const float* X         [[buffer(1)]],
    device float*       Y         [[buffer(2)]],
    constant uint&      M         [[buffer(3)]],
    constant uint&      N         [[buffer(4)]],  // inter_dim
    constant uint&      K         [[buffer(5)]]   // hidden_dim
    ,uint2 tg_pos                 [[threadgroup_position_in_grid]]
    ,ushort tiitg                 [[thread_index_in_threadgroup]]
    ,ushort sgitg                 [[simdgroup_index_in_threadgroup]])
{
    // 6144 halfs = 12 KB threadgroup memory (same as AoS fused kernel).
    threadgroup half shmem_gusp[6144];
    threadgroup half* sa     = shmem_gusp;
    threadgroup half* sb_g   = shmem_gusp + TILE_M * TILE_K_64;
    threadgroup half* sb_u   = shmem_gusp + TILE_M * TILE_K_64 + TILE_N * TILE_K_64;

    uint tile_m_start = tg_pos.y * TILE_M;
    uint tile_n_start = tg_pos.x * TILE_N;

    ushort sg_r = sgitg / SG_COLS;
    ushort sg_c = sgitg % SG_COLS;

    simdgroup_float8x8 mc_g[2][2];
    simdgroup_float8x8 mc_u[2][2];
    FOR_UNROLL (ushort i = 0; i < 2; i++)
        FOR_UNROLL (ushort j = 0; j < 2; j++) {
            mc_g[i][j] = make_filled_simdgroup_matrix<float, 8>(0.f);
            mc_u[i][j] = make_filled_simdgroup_matrix<float, 8>(0.f);
        }

    uint num_blocks_per_row = (K + Q8B_GROUP_SIZE - 1) / Q8B_GROUP_SIZE;
    // stripe_stride (bytes) for paired layout = num_blocks_per_row * 2176
    uint stripe_stride = num_blocks_per_row * 2176u;

    uint row_group = tile_n_start / 32u;
    uint rg_base = row_group * stripe_stride;

    uint num_k_tiles = (K + TILE_K_64 - 1) / TILE_K_64;

    for (uint kt = 0; kt < num_k_tiles; kt++) {
        uint k_base = kt * TILE_K_64;

        // ---- Load A tile: identical to AoS fused. ----
        {
            ushort row = tiitg >> 2;
            ushort col_group = tiitg & 3;
            ushort k_start = col_group << 4;

            uint gm = tile_m_start + row;
            uint gk = k_base + k_start;
            threadgroup half* sa_ptr = sa + row * TILE_K_64 + k_start;

            if (FC_BC_M || FC_BC_K) {
                if (gm < M && gk + 15 < K) {
                    device const float4* x_ptr = (device const float4*)(X + gm * K + gk);
                    float4 v0 = x_ptr[0];
                    float4 v1 = x_ptr[1];
                    float4 v2 = x_ptr[2];
                    float4 v3 = x_ptr[3];
                    sa_ptr[0]  = (half)v0.x; sa_ptr[1]  = (half)v0.y;
                    sa_ptr[2]  = (half)v0.z; sa_ptr[3]  = (half)v0.w;
                    sa_ptr[4]  = (half)v1.x; sa_ptr[5]  = (half)v1.y;
                    sa_ptr[6]  = (half)v1.z; sa_ptr[7]  = (half)v1.w;
                    sa_ptr[8]  = (half)v2.x; sa_ptr[9]  = (half)v2.y;
                    sa_ptr[10] = (half)v2.z; sa_ptr[11] = (half)v2.w;
                    sa_ptr[12] = (half)v3.x; sa_ptr[13] = (half)v3.y;
                    sa_ptr[14] = (half)v3.z; sa_ptr[15] = (half)v3.w;
                } else {
                    FOR_UNROLL (ushort i = 0; i < 16; i++) {
                        uint gk_i = gk + i;
                        sa_ptr[i] = (gm < M && gk_i < K) ? (half)X[gm * K + gk_i] : (half)0.0h;
                    }
                }
            } else {
                device const float4* x_ptr = (device const float4*)(X + gm * K + gk);
                float4 v0 = x_ptr[0];
                float4 v1 = x_ptr[1];
                float4 v2 = x_ptr[2];
                float4 v3 = x_ptr[3];
                sa_ptr[0]  = (half)v0.x; sa_ptr[1]  = (half)v0.y;
                sa_ptr[2]  = (half)v0.z; sa_ptr[3]  = (half)v0.w;
                sa_ptr[4]  = (half)v1.x; sa_ptr[5]  = (half)v1.y;
                sa_ptr[6]  = (half)v1.z; sa_ptr[7]  = (half)v1.w;
                sa_ptr[8]  = (half)v2.x; sa_ptr[9]  = (half)v2.y;
                sa_ptr[10] = (half)v2.z; sa_ptr[11] = (half)v2.w;
                sa_ptr[12] = (half)v3.x; sa_ptr[13] = (half)v3.y;
                sa_ptr[14] = (half)v3.z; sa_ptr[15] = (half)v3.w;
            }
        }

        // ---- Load B-gate AND B-up tiles from packed layout ----
        {
            ushort n_local = tiitg >> 2;
            ushort t_in_row = tiitg & 3;
            ushort k_offset = t_in_row * 8;
            uint gn = tile_n_start + n_local;

            uint block_idx_0 = k_base / Q8B_GROUP_SIZE;
            uint block_base_0 = rg_base + block_idx_0 * 2176u;
            uint block_idx_1 = (k_base + 32) / Q8B_GROUP_SIZE;
            uint block_base_1 = rg_base + block_idx_1 * 2176u;

            threadgroup half* sb_g_row_0 = sb_g + n_local * TILE_K_64 + k_offset;
            threadgroup half* sb_u_row_0 = sb_u + n_local * TILE_K_64 + k_offset;
            threadgroup half* sb_g_row_1 = sb_g + n_local * TILE_K_64 + 32 + k_offset;
            threadgroup half* sb_u_row_1 = sb_u + n_local * TILE_K_64 + 32 + k_offset;

            if (FC_BC_N || FC_BC_K) {
                // Gate scale + qdata, pass 0
                if (gn < N && k_base + k_offset < K) {
                    half scale_g = as_type<half>(*(device const ushort*)(W_gate_up + block_base_0 + n_local * 2u));
                    device const char* qd_g = (device const char*)(W_gate_up + block_base_0 + 128u + n_local * 32u + k_offset);
                    uint krem = K - (k_base + k_offset);
                    ushort cnt = (krem >= 8) ? 8 : (ushort)krem;
                    if (cnt == 8) {
                        sb_g_row_0[0] = scale_g * (half)qd_g[0];
                        sb_g_row_0[1] = scale_g * (half)qd_g[1];
                        sb_g_row_0[2] = scale_g * (half)qd_g[2];
                        sb_g_row_0[3] = scale_g * (half)qd_g[3];
                        sb_g_row_0[4] = scale_g * (half)qd_g[4];
                        sb_g_row_0[5] = scale_g * (half)qd_g[5];
                        sb_g_row_0[6] = scale_g * (half)qd_g[6];
                        sb_g_row_0[7] = scale_g * (half)qd_g[7];
                    } else {
                        for (ushort i = 0; i < cnt; i++) sb_g_row_0[i] = scale_g * (half)qd_g[i];
                        for (ushort i = cnt; i < 8; i++) sb_g_row_0[i] = (half)0.0h;
                    }
                } else {
                    FOR_UNROLL (ushort i = 0; i < 8; i++) sb_g_row_0[i] = (half)0.0h;
                }
                // Up scale + qdata, pass 0
                if (gn < N && k_base + k_offset < K) {
                    half scale_u = as_type<half>(*(device const ushort*)(W_gate_up + block_base_0 + 64u + n_local * 2u));
                    device const char* qd_u = (device const char*)(W_gate_up + block_base_0 + 1152u + n_local * 32u + k_offset);
                    uint krem = K - (k_base + k_offset);
                    ushort cnt = (krem >= 8) ? 8 : (ushort)krem;
                    if (cnt == 8) {
                        sb_u_row_0[0] = scale_u * (half)qd_u[0];
                        sb_u_row_0[1] = scale_u * (half)qd_u[1];
                        sb_u_row_0[2] = scale_u * (half)qd_u[2];
                        sb_u_row_0[3] = scale_u * (half)qd_u[3];
                        sb_u_row_0[4] = scale_u * (half)qd_u[4];
                        sb_u_row_0[5] = scale_u * (half)qd_u[5];
                        sb_u_row_0[6] = scale_u * (half)qd_u[6];
                        sb_u_row_0[7] = scale_u * (half)qd_u[7];
                    } else {
                        for (ushort i = 0; i < cnt; i++) sb_u_row_0[i] = scale_u * (half)qd_u[i];
                        for (ushort i = cnt; i < 8; i++) sb_u_row_0[i] = (half)0.0h;
                    }
                } else {
                    FOR_UNROLL (ushort i = 0; i < 8; i++) sb_u_row_0[i] = (half)0.0h;
                }
                // Gate, pass 1
                if (gn < N && k_base + 32 + k_offset < K) {
                    half scale_g = as_type<half>(*(device const ushort*)(W_gate_up + block_base_1 + n_local * 2u));
                    device const char* qd_g = (device const char*)(W_gate_up + block_base_1 + 128u + n_local * 32u + k_offset);
                    uint krem = K - (k_base + 32 + k_offset);
                    ushort cnt = (krem >= 8) ? 8 : (ushort)krem;
                    if (cnt == 8) {
                        sb_g_row_1[0] = scale_g * (half)qd_g[0];
                        sb_g_row_1[1] = scale_g * (half)qd_g[1];
                        sb_g_row_1[2] = scale_g * (half)qd_g[2];
                        sb_g_row_1[3] = scale_g * (half)qd_g[3];
                        sb_g_row_1[4] = scale_g * (half)qd_g[4];
                        sb_g_row_1[5] = scale_g * (half)qd_g[5];
                        sb_g_row_1[6] = scale_g * (half)qd_g[6];
                        sb_g_row_1[7] = scale_g * (half)qd_g[7];
                    } else {
                        for (ushort i = 0; i < cnt; i++) sb_g_row_1[i] = scale_g * (half)qd_g[i];
                        for (ushort i = cnt; i < 8; i++) sb_g_row_1[i] = (half)0.0h;
                    }
                } else {
                    FOR_UNROLL (ushort i = 0; i < 8; i++) sb_g_row_1[i] = (half)0.0h;
                }
                // Up, pass 1
                if (gn < N && k_base + 32 + k_offset < K) {
                    half scale_u = as_type<half>(*(device const ushort*)(W_gate_up + block_base_1 + 64u + n_local * 2u));
                    device const char* qd_u = (device const char*)(W_gate_up + block_base_1 + 1152u + n_local * 32u + k_offset);
                    uint krem = K - (k_base + 32 + k_offset);
                    ushort cnt = (krem >= 8) ? 8 : (ushort)krem;
                    if (cnt == 8) {
                        sb_u_row_1[0] = scale_u * (half)qd_u[0];
                        sb_u_row_1[1] = scale_u * (half)qd_u[1];
                        sb_u_row_1[2] = scale_u * (half)qd_u[2];
                        sb_u_row_1[3] = scale_u * (half)qd_u[3];
                        sb_u_row_1[4] = scale_u * (half)qd_u[4];
                        sb_u_row_1[5] = scale_u * (half)qd_u[5];
                        sb_u_row_1[6] = scale_u * (half)qd_u[6];
                        sb_u_row_1[7] = scale_u * (half)qd_u[7];
                    } else {
                        for (ushort i = 0; i < cnt; i++) sb_u_row_1[i] = scale_u * (half)qd_u[i];
                        for (ushort i = cnt; i < 8; i++) sb_u_row_1[i] = (half)0.0h;
                    }
                } else {
                    FOR_UNROLL (ushort i = 0; i < 8; i++) sb_u_row_1[i] = (half)0.0h;
                }
            } else {
                // Aligned fast path: no boundary checks.
                {
                    half scale_g = as_type<half>(*(device const ushort*)(W_gate_up + block_base_0 + n_local * 2u));
                    device const char* qd_g = (device const char*)(W_gate_up + block_base_0 + 128u + n_local * 32u + k_offset);
                    sb_g_row_0[0] = scale_g * (half)qd_g[0];
                    sb_g_row_0[1] = scale_g * (half)qd_g[1];
                    sb_g_row_0[2] = scale_g * (half)qd_g[2];
                    sb_g_row_0[3] = scale_g * (half)qd_g[3];
                    sb_g_row_0[4] = scale_g * (half)qd_g[4];
                    sb_g_row_0[5] = scale_g * (half)qd_g[5];
                    sb_g_row_0[6] = scale_g * (half)qd_g[6];
                    sb_g_row_0[7] = scale_g * (half)qd_g[7];
                }
                {
                    half scale_u = as_type<half>(*(device const ushort*)(W_gate_up + block_base_0 + 64u + n_local * 2u));
                    device const char* qd_u = (device const char*)(W_gate_up + block_base_0 + 1152u + n_local * 32u + k_offset);
                    sb_u_row_0[0] = scale_u * (half)qd_u[0];
                    sb_u_row_0[1] = scale_u * (half)qd_u[1];
                    sb_u_row_0[2] = scale_u * (half)qd_u[2];
                    sb_u_row_0[3] = scale_u * (half)qd_u[3];
                    sb_u_row_0[4] = scale_u * (half)qd_u[4];
                    sb_u_row_0[5] = scale_u * (half)qd_u[5];
                    sb_u_row_0[6] = scale_u * (half)qd_u[6];
                    sb_u_row_0[7] = scale_u * (half)qd_u[7];
                }
                {
                    half scale_g = as_type<half>(*(device const ushort*)(W_gate_up + block_base_1 + n_local * 2u));
                    device const char* qd_g = (device const char*)(W_gate_up + block_base_1 + 128u + n_local * 32u + k_offset);
                    sb_g_row_1[0] = scale_g * (half)qd_g[0];
                    sb_g_row_1[1] = scale_g * (half)qd_g[1];
                    sb_g_row_1[2] = scale_g * (half)qd_g[2];
                    sb_g_row_1[3] = scale_g * (half)qd_g[3];
                    sb_g_row_1[4] = scale_g * (half)qd_g[4];
                    sb_g_row_1[5] = scale_g * (half)qd_g[5];
                    sb_g_row_1[6] = scale_g * (half)qd_g[6];
                    sb_g_row_1[7] = scale_g * (half)qd_g[7];
                }
                {
                    half scale_u = as_type<half>(*(device const ushort*)(W_gate_up + block_base_1 + 64u + n_local * 2u));
                    device const char* qd_u = (device const char*)(W_gate_up + block_base_1 + 1152u + n_local * 32u + k_offset);
                    sb_u_row_1[0] = scale_u * (half)qd_u[0];
                    sb_u_row_1[1] = scale_u * (half)qd_u[1];
                    sb_u_row_1[2] = scale_u * (half)qd_u[2];
                    sb_u_row_1[3] = scale_u * (half)qd_u[3];
                    sb_u_row_1[4] = scale_u * (half)qd_u[4];
                    sb_u_row_1[5] = scale_u * (half)qd_u[5];
                    sb_u_row_1[6] = scale_u * (half)qd_u[6];
                    sb_u_row_1[7] = scale_u * (half)qd_u[7];
                }
            }
        }

        threadgroup_barrier(mem_flags::mem_threadgroup);

        // ---- MMA: same as AoS fused. ----
        FOR_UNROLL (ushort ks = 0; ks < TILE_K_64; ks += 8) {
            simdgroup_half8x8 ma[2];
            simdgroup_barrier(mem_flags::mem_none);
            simdgroup_load(ma[0], sa + (sg_r * 16 + 0) * TILE_K_64 + ks, TILE_K_64);
            simdgroup_load(ma[1], sa + (sg_r * 16 + 8) * TILE_K_64 + ks, TILE_K_64);

            simdgroup_half8x8 mb_g[2];
            simdgroup_barrier(mem_flags::mem_none);
            simdgroup_load(mb_g[0], sb_g + (sg_c * 16 + 0) * TILE_K_64 + ks, TILE_K_64, ulong2(0,0), true);
            simdgroup_load(mb_g[1], sb_g + (sg_c * 16 + 8) * TILE_K_64 + ks, TILE_K_64, ulong2(0,0), true);

            simdgroup_barrier(mem_flags::mem_none);
            simdgroup_multiply_accumulate(mc_g[0][0], ma[0], mb_g[0], mc_g[0][0]);
            simdgroup_multiply_accumulate(mc_g[0][1], ma[0], mb_g[1], mc_g[0][1]);
            simdgroup_multiply_accumulate(mc_g[1][0], ma[1], mb_g[0], mc_g[1][0]);
            simdgroup_multiply_accumulate(mc_g[1][1], ma[1], mb_g[1], mc_g[1][1]);

            simdgroup_half8x8 mb_u[2];
            simdgroup_barrier(mem_flags::mem_none);
            simdgroup_load(mb_u[0], sb_u + (sg_c * 16 + 0) * TILE_K_64 + ks, TILE_K_64, ulong2(0,0), true);
            simdgroup_load(mb_u[1], sb_u + (sg_c * 16 + 8) * TILE_K_64 + ks, TILE_K_64, ulong2(0,0), true);

            simdgroup_barrier(mem_flags::mem_none);
            simdgroup_multiply_accumulate(mc_u[0][0], ma[0], mb_u[0], mc_u[0][0]);
            simdgroup_multiply_accumulate(mc_u[0][1], ma[0], mb_u[1], mc_u[0][1]);
            simdgroup_multiply_accumulate(mc_u[1][0], ma[1], mb_u[0], mc_u[1][0]);
            simdgroup_multiply_accumulate(mc_u[1][1], ma[1], mb_u[1], mc_u[1][1]);
        }

        threadgroup_barrier(mem_flags::mem_threadgroup);
    }

    // ---- SwiGLU epilogue: identical to AoS fused. ----
    threadgroup float* sc_gate = (threadgroup float*)shmem_gusp;
    threadgroup float* sc_up   = (threadgroup float*)shmem_gusp + 4 * 256;
    threadgroup float* my_sc_gate = sc_gate + sgitg * 256;
    threadgroup float* my_sc_up   = sc_up   + sgitg * 256;

    FOR_UNROLL (ushort i = 0; i < 2; i++)
        FOR_UNROLL (ushort j = 0; j < 2; j++) {
            simdgroup_store(mc_g[i][j], my_sc_gate + (i * 8) * 16 + (j * 8), 16);
            simdgroup_store(mc_u[i][j], my_sc_up   + (i * 8) * 16 + (j * 8), 16);
        }
    threadgroup_barrier(mem_flags::mem_threadgroup);

    uint sg_m_base = tile_m_start + sg_r * 16;
    uint sg_n_base = tile_n_start + sg_c * 16;

    ushort lane = tiitg % 32;
    if (FC_BC_M || FC_BC_N) {
        for (ushort idx = lane; idx < 256; idx += 32) {
            ushort local_m = idx / 16;
            ushort local_n = idx % 16;
            uint gm = sg_m_base + local_m;
            uint gn = sg_n_base + local_n;
            if (gm < M && gn < N) {
                float g = my_sc_gate[local_m * 16 + local_n];
                float u = my_sc_up  [local_m * 16 + local_n];
                float sig = 1.0f / (1.0f + exp(-g));
                Y[gm * N + gn] = g * sig * u;
            }
        }
    } else {
        for (ushort idx = lane; idx < 256; idx += 32) {
            ushort local_m = idx / 16;
            ushort local_n = idx % 16;
            uint gm = sg_m_base + local_m;
            uint gn = sg_n_base + local_n;
            float g = my_sc_gate[local_m * 16 + local_n];
            float u = my_sc_up  [local_m * 16 + local_n];
            float sig = 1.0f / (1.0f + exp(-g));
            Y[gm * N + gn] = g * sig * u;
        }
    }
}

// ============================================================================
// rmsnorm_batched: RMS Normalization for a batch of vectors
//
// Each threadgroup normalizes one row: out[batch_idx, :] = normalize(x[batch_idx, :])
//
// Dispatch: threadgroups = batch_size, threads_per_threadgroup = norm_tg_size
// ============================================================================

